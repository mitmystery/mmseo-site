---
interface Props {
  heading: string;
  subheading?: string;
  phone: string;
  ctaText?: string;
  ctaHref?: string;
}

const {
  heading,
  subheading,
  phone,
  ctaText = 'Book a Free Consultation',
  ctaHref = '#contact',
} = Astro.props;

const telHref = `tel:${phone.replace(/[\s\-\(\)]/g, '')}`;
---

<section class="cb-section section-mid section-pad">
  <div class="container cb-inner reveal">
    <div class="cb-text">
      <h2 class="cb-h2">{heading}</h2>
      {subheading && <p class="cb-sub">{subheading}</p>}
    </div>
    <div class="cb-actions">
      <a href={telHref} class="cb-phone" aria-label={`Call ${phone}`}>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.05 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 5.93 5.93l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 16.92z"/>
        </svg>
        {phone}
      </a>
      <a href={ctaHref} class="btn-primary">{ctaText}</a>
    </div>
  </div>
</section>

<style>
  .cb-section {
    position: relative;
  }

  .cb-inner {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: flex-start;
  }

  @media (min-width: 768px) {
    .cb-inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 3rem;
    }
  }

  .cb-text {
    flex: 1;
  }

  .cb-h2 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--chalk);
    margin: 0;
  }

  .cb-sub {
    font-size: 1rem;
    color: rgba(248, 247, 242, 0.65);
    margin-top: 0.625rem;
    line-height: 1.65;
  }

  .cb-actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
    flex-shrink: 0;
  }

  @media (min-width: 480px) {
    .cb-actions {
      flex-direction: row;
      align-items: center;
    }
  }

  .cb-phone {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.125rem, 2.5vw, 1.5rem);
    font-weight: 700;
    color: var(--chalk);
    text-decoration: none;
    letter-spacing: -0.01em;
    transition: color 0.2s ease;
    white-space: nowrap;
  }

  .cb-phone:hover {
    color: var(--accent);
  }

  .cb-phone svg {
    color: var(--accent);
    flex-shrink: 0;
  }
</style>
