---
/**
 * Nav.astro — sticky site navigation.
 *
 * Behaviour:
 *   • Transparent at top → ink + backdrop-blur once scrolled 60px
 *   • Hides on scroll-down (>120px from top), reappears on scroll-up
 *   • Mobile: hamburger toggles full-screen overlay
 *   • Desktop: "Services" has a hover dropdown to all service pages
 *   • Mobile: "Services" expands inline to show service sub-links
 *
 * All links use absolute paths with hashes so they work from any page.
 */

const services = [
  { label: 'SEO Strategy',    href: '/seo-strategy/' },
  { label: 'Technical SEO',   href: '/technical-seo/' },
  { label: 'Keyword Research',href: '/keyword-research/' },
  { label: 'On-Page SEO',     href: '/on-page-seo/' },
  { label: 'Link Building',   href: '/off-page-seo/' },
  { label: 'Local SEO',       href: '/local-seo/' },
];
---

<header id="site-nav" aria-label="Site navigation">
  <div class="nav-inner">
    <!-- Logotype -->
    <a href="/" class="nav-logo" aria-label="MM SEO — Back to home">
      MM<span class="accent">SEO</span>
    </a>

    <!-- Desktop nav -->
    <nav class="nav-desktop" aria-label="Main">

      <!-- Services dropdown -->
      <div class="nav-dropdown" id="services-dropdown">
        <button
          class="nav-link nav-dropdown-trigger"
          aria-haspopup="true"
          aria-expanded="false"
          aria-controls="services-menu"
        >
          Services
          <svg class="chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="dropdown-panel" id="services-menu" role="menu" aria-label="Services">
          {services.map(s => (
            <a href={s.href} class="dropdown-link" role="menuitem">{s.label}</a>
          ))}
        </div>
      </div>

      <a href="/#results"      class="nav-link">Results</a>
      <a href="/#testimonials" class="nav-link">Testimonials</a>
      <a href="/#faq"          class="nav-link">FAQs</a>
      <a href="/#contact"      class="btn-primary nav-cta">Let's Talk</a>
    </nav>

    <!-- Mobile burger button -->
    <button
      id="nav-burger"
      class="nav-burger"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="nav-overlay"
    >
      <span class="burger-line"></span>
      <span class="burger-line"></span>
      <span class="burger-line"></span>
    </button>
  </div>
</header>

<!-- Mobile full-screen overlay -->
<div id="nav-overlay" class="nav-overlay" aria-hidden="true" role="dialog" aria-label="Navigation menu">
  <button
    id="nav-close"
    class="nav-close"
    aria-label="Close navigation menu"
  >
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <line x1="18" y1="6" x2="6" y2="18"/>
      <line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>

  <nav class="nav-overlay-links" aria-label="Mobile navigation">

    <!-- Services accordion -->
    <div class="mobile-services">
      <button class="nav-overlay-link mobile-services-trigger" aria-expanded="false" aria-controls="mobile-services-list">
        Services
        <svg class="mobile-chevron" width="14" height="14" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div class="mobile-services-list" id="mobile-services-list" aria-hidden="true">
        {services.map(s => (
          <a href={s.href} class="mobile-service-link">{s.label}</a>
        ))}
      </div>
    </div>

    <a href="/#results"      class="nav-overlay-link">Results</a>
    <a href="/#testimonials" class="nav-overlay-link">Testimonials</a>
    <a href="/#faq"          class="nav-overlay-link">FAQs</a>
    <a href="/#contact"      class="btn-primary nav-overlay-cta">Let's Talk</a>
  </nav>
</div>

<style>
  /* ── Header shell ─────────────────────────────────────────── */
  #site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background-color: transparent;
    border-bottom: 1px solid transparent;
    transform: translateY(0);
    transition:
      background-color 0.3s ease,
      backdrop-filter  0.3s ease,
      -webkit-backdrop-filter 0.3s ease,
      border-color     0.3s ease,
      transform        0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #site-nav.is-scrolled {
    background-color: rgba(10, 10, 15, 0.88);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom-color: rgba(255, 255, 255, 0.06);
  }

  #site-nav.is-hidden {
    transform: translateY(-100%);
  }

  /* ── Inner layout ─────────────────────────────────────────── */
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    margin-inline: auto;
    padding: 0 clamp(1.25rem, 5vw, 3rem);
    height: 68px;
  }

  /* ── Logotype ─────────────────────────────────────────────── */
  .nav-logo {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 1.25rem;
    letter-spacing: 0.06em;
    color: #fff;
    text-decoration: none;
    line-height: 1;
  }

  .nav-logo .accent {
    color: #FF6826;
  }

  /* ── Desktop nav ──────────────────────────────────────────── */
  .nav-desktop {
    display: none;
    align-items: center;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .nav-desktop {
      display: flex;
    }
  }

  .nav-link {
    font-size: 0.9375rem;
    color: rgba(248, 247, 242, 0.8);
    text-decoration: none;
    letter-spacing: -0.01em;
    transition: color 0.2s ease;
  }

  .nav-link:hover {
    color: #fff;
  }

  .nav-cta {
    font-size: 0.875rem;
    padding: 0.625rem 1.25rem;
  }

  /* ── Services dropdown ────────────────────────────────────── */
  .nav-dropdown {
    position: relative;
  }

  .nav-dropdown-trigger {
    display: flex;
    align-items: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    font-family: inherit;
    font-size: 0.9375rem;
  }

  .chevron {
    color: rgba(248, 247, 242, 0.5);
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }

  .nav-dropdown-trigger[aria-expanded="true"] .chevron {
    transform: rotate(180deg);
  }

  .dropdown-panel {
    position: absolute;
    top: calc(100% + 18px);
    left: 50%;
    transform: translateX(-50%);
    background: rgba(10, 10, 15, 0.96);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    padding: 8px;
    min-width: 200px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    opacity: 0;
    pointer-events: none;
    transform: translateX(-50%) translateY(-6px);
    transition: opacity 0.18s ease, transform 0.18s ease;
    z-index: 10;
  }

  /* Arrow notch */
  .dropdown-panel::before {
    content: '';
    position: absolute;
    top: -5px;
    left: 50%;
    transform: translateX(-50%) rotate(45deg);
    width: 8px;
    height: 8px;
    background: rgba(10, 10, 15, 0.96);
    border-left: 1px solid rgba(255, 255, 255, 0.08);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .nav-dropdown-trigger[aria-expanded="true"] + .dropdown-panel {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  .dropdown-link {
    display: block;
    padding: 9px 14px;
    color: rgba(248, 247, 242, 0.75);
    text-decoration: none;
    font-size: 0.875rem;
    border-radius: 5px;
    transition: background-color 0.15s ease, color 0.15s ease;
    white-space: nowrap;
  }

  .dropdown-link:hover {
    background-color: rgba(255, 104, 38, 0.12);
    color: #fff;
  }

  /* ── Hamburger ────────────────────────────────────────────── */
  .nav-burger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    border-radius: 0.25rem;
    transition: background-color 0.2s ease;
  }

  .nav-burger:hover {
    background-color: rgba(255, 255, 255, 0.06);
  }

  .burger-line {
    display: block;
    width: 100%;
    height: 1.5px;
    background-color: #fff;
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease, width 0.3s ease;
    transform-origin: center;
  }

  /* Burger → X when open */
  .nav-burger[aria-expanded="true"] .burger-line:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .nav-burger[aria-expanded="true"] .burger-line:nth-child(2) {
    opacity: 0;
    width: 0;
  }
  .nav-burger[aria-expanded="true"] .burger-line:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  @media (min-width: 768px) {
    .nav-burger {
      display: none;
    }
  }

  /* ── Mobile overlay ───────────────────────────────────────── */
  .nav-overlay {
    position: fixed;
    inset: 0;
    z-index: 99;
    background-color: #0A0A0F;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .nav-overlay.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .nav-close {
    position: absolute;
    top: 1.25rem;
    right: clamp(1.25rem, 5vw, 3rem);
    background: none;
    border: none;
    color: rgba(248, 247, 242, 0.6);
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 0.25rem;
    transition: color 0.2s ease;
  }

  .nav-close:hover {
    color: #fff;
  }

  .nav-overlay-links {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.75rem;
  }

  .nav-overlay-link {
    font-family: 'Syne', sans-serif;
    font-weight: 600;
    font-size: clamp(1.5rem, 5vw, 2rem);
    color: rgba(248, 247, 242, 0.8);
    text-decoration: none;
    letter-spacing: -0.02em;
    transition: color 0.2s ease;
  }

  .nav-overlay-link:hover {
    color: #fff;
  }

  .nav-overlay-cta {
    margin-top: 0.5rem;
  }

  /* ── Mobile services accordion ────────────────────────────── */
  .mobile-services {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .mobile-services-trigger {
    display: flex;
    align-items: center;
    gap: 8px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    font-family: 'Syne', sans-serif;
  }

  .mobile-chevron {
    color: rgba(248, 247, 242, 0.5);
    transition: transform 0.25s ease;
    flex-shrink: 0;
  }

  .mobile-services-trigger[aria-expanded="true"] .mobile-chevron {
    transform: rotate(180deg);
  }

  .mobile-services-list {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition: max-height 0.3s ease, opacity 0.25s ease, margin-top 0.25s ease;
    margin-top: 0;
  }

  .mobile-services-list.is-open {
    max-height: 400px;
    opacity: 1;
    margin-top: 1rem;
  }

  .mobile-service-link {
    font-size: 1rem;
    color: rgba(248, 247, 242, 0.6);
    text-decoration: none;
    letter-spacing: -0.01em;
    transition: color 0.2s ease;
    padding: 2px 0;
  }

  .mobile-service-link:hover {
    color: #FF6826;
  }
</style>

<script>
  const nav      = document.getElementById('site-nav') as HTMLElement;
  const burger   = document.getElementById('nav-burger') as HTMLButtonElement;
  const overlay  = document.getElementById('nav-overlay') as HTMLElement;
  const closeBtn = document.getElementById('nav-close') as HTMLButtonElement;

  // ── Scroll behaviour: scrolled state + hide/show ────────────
  let lastY = window.scrollY;

  window.addEventListener('scroll', () => {
    const y = window.scrollY;

    // Scrolled background
    nav.classList.toggle('is-scrolled', y > 60);

    // Hide on scroll-down past 120px, show on scroll-up
    if (y > 120) {
      if (y > lastY + 8) {
        nav.classList.add('is-hidden');
      } else if (y < lastY - 8) {
        nav.classList.remove('is-hidden');
      }
    } else {
      nav.classList.remove('is-hidden');
    }

    lastY = y;
  }, { passive: true });

  // ── Desktop dropdown ─────────────────────────────────────────
  const navDropdown     = document.getElementById('services-dropdown') as HTMLElement;
  const dropdownTrigger = document.querySelector('.nav-dropdown-trigger') as HTMLButtonElement;
  const dropdownPanel   = document.getElementById('services-menu') as HTMLElement;

  let closeTimer: ReturnType<typeof setTimeout> | null = null;

  function openDropdown() {
    if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
    dropdownTrigger?.setAttribute('aria-expanded', 'true');
  }

  function scheduleClose() {
    closeTimer = setTimeout(() => {
      dropdownTrigger?.setAttribute('aria-expanded', 'false');
    }, 200);
  }

  // Hover intent: open on enter, delayed close on leave
  navDropdown?.addEventListener('mouseenter', openDropdown);
  navDropdown?.addEventListener('mouseleave', scheduleClose);

  // Click toggle (keyboard / touch fallback)
  dropdownTrigger?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = dropdownTrigger.getAttribute('aria-expanded') === 'true';
    if (isOpen) {
      dropdownTrigger.setAttribute('aria-expanded', 'false');
    } else {
      openDropdown();
    }
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (!navDropdown?.contains(e.target as Node)) {
      dropdownTrigger?.setAttribute('aria-expanded', 'false');
    }
  });

  // Close on link click
  dropdownPanel?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      dropdownTrigger?.setAttribute('aria-expanded', 'false');
    });
  });

  // ── Mobile overlay toggle ────────────────────────────────────
  function openMenu() {
    overlay.classList.add('is-open');
    overlay.setAttribute('aria-hidden', 'false');
    burger.setAttribute('aria-expanded', 'true');
    document.body.classList.add('nav-open');
    closeBtn.focus();
  }

  function closeMenu() {
    overlay.classList.remove('is-open');
    overlay.setAttribute('aria-hidden', 'true');
    burger.setAttribute('aria-expanded', 'false');
    document.body.classList.remove('nav-open');
    burger.focus();
  }

  burger.addEventListener('click', openMenu);
  closeBtn.addEventListener('click', closeMenu);

  // Close on non-services overlay link click
  overlay.querySelectorAll('a:not(.mobile-service-link)').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  // Close on service sub-link click
  overlay.querySelectorAll('.mobile-service-link').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overlay.classList.contains('is-open')) {
      closeMenu();
    }
  });

  // ── Mobile services accordion ────────────────────────────────
  const mobileServicesTrigger = document.querySelector('.mobile-services-trigger') as HTMLButtonElement;
  const mobileServicesList    = document.getElementById('mobile-services-list') as HTMLElement;

  mobileServicesTrigger?.addEventListener('click', () => {
    const isOpen = mobileServicesTrigger.getAttribute('aria-expanded') === 'true';
    mobileServicesTrigger.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
    mobileServicesList.classList.toggle('is-open', !isOpen);
    mobileServicesList.setAttribute('aria-hidden', isOpen ? 'true' : 'false');
  });
</script>
