---
/**
 * Nav.astro — sticky site navigation.
 *
 * Behaviour:
 *   • Transparent at top → ink + backdrop-blur once scrolled 60px
 *   • Hides on scroll-down (>120px from top), reappears on scroll-up
 *   • Mobile: hamburger toggles full-screen overlay
 *
 * All links use absolute paths with hashes so they work from any page.
 */
---

<header id="site-nav" aria-label="Site navigation">
  <div class="nav-inner">
    <!-- Logotype -->
    <a href="/" class="nav-logo" aria-label="MM SEO — Back to home">
      MM<span class="accent">SEO</span>
    </a>

    <!-- Desktop nav -->
    <nav class="nav-desktop" aria-label="Main">
      <a href="/#services"     class="nav-link">Services</a>
      <a href="/#results"      class="nav-link">Results</a>
      <a href="/#testimonials" class="nav-link">Testimonials</a>
      <a href="/#faq"          class="nav-link">FAQs</a>
      <a href="/#contact"      class="btn-primary nav-cta">Let's Talk</a>
    </nav>

    <!-- Mobile burger button -->
    <button
      id="nav-burger"
      class="nav-burger"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="nav-overlay"
    >
      <span class="burger-line"></span>
      <span class="burger-line"></span>
      <span class="burger-line"></span>
    </button>
  </div>
</header>

<!-- Mobile full-screen overlay -->
<div id="nav-overlay" class="nav-overlay" aria-hidden="true" role="dialog" aria-label="Navigation menu">
  <button
    id="nav-close"
    class="nav-close"
    aria-label="Close navigation menu"
  >
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <line x1="18" y1="6" x2="6" y2="18"/>
      <line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>

  <nav class="nav-overlay-links" aria-label="Mobile navigation">
    <a href="/#services"     class="nav-overlay-link">Services</a>
    <a href="/#results"      class="nav-overlay-link">Results</a>
    <a href="/#testimonials" class="nav-overlay-link">Testimonials</a>
    <a href="/#faq"          class="nav-overlay-link">FAQs</a>
    <a href="/#contact"      class="btn-primary nav-overlay-cta">Let's Talk</a>
  </nav>
</div>

<style>
  /* ── Header shell ─────────────────────────────────────────── */
  #site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background-color: transparent;
    border-bottom: 1px solid transparent;
    transform: translateY(0);
    transition:
      background-color 0.3s ease,
      backdrop-filter  0.3s ease,
      -webkit-backdrop-filter 0.3s ease,
      border-color     0.3s ease,
      transform        0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #site-nav.is-scrolled {
    background-color: rgba(10, 10, 15, 0.88);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom-color: rgba(255, 255, 255, 0.06);
  }

  #site-nav.is-hidden {
    transform: translateY(-100%);
  }

  /* ── Inner layout ─────────────────────────────────────────── */
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    margin-inline: auto;
    padding: 0 clamp(1.25rem, 5vw, 3rem);
    height: 68px;
  }

  /* ── Logotype ─────────────────────────────────────────────── */
  .nav-logo {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 1.25rem;
    letter-spacing: 0.06em;
    color: #fff;
    text-decoration: none;
    line-height: 1;
  }

  .nav-logo .accent {
    color: #FF6826;
  }

  /* ── Desktop nav ──────────────────────────────────────────── */
  .nav-desktop {
    display: none;
    align-items: center;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .nav-desktop {
      display: flex;
    }
  }

  .nav-cta {
    font-size: 0.875rem;
    padding: 0.625rem 1.25rem;
  }

  /* ── Hamburger ────────────────────────────────────────────── */
  .nav-burger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    border-radius: 0.25rem;
    transition: background-color 0.2s ease;
  }

  .nav-burger:hover {
    background-color: rgba(255, 255, 255, 0.06);
  }

  .burger-line {
    display: block;
    width: 100%;
    height: 1.5px;
    background-color: #fff;
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease, width 0.3s ease;
    transform-origin: center;
  }

  /* Burger → X when open */
  .nav-burger[aria-expanded="true"] .burger-line:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .nav-burger[aria-expanded="true"] .burger-line:nth-child(2) {
    opacity: 0;
    width: 0;
  }
  .nav-burger[aria-expanded="true"] .burger-line:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  @media (min-width: 768px) {
    .nav-burger {
      display: none;
    }
  }

  /* ── Mobile overlay ───────────────────────────────────────── */
  .nav-overlay {
    position: fixed;
    inset: 0;
    z-index: 99;
    background-color: #0A0A0F;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .nav-overlay.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .nav-close {
    position: absolute;
    top: 1.25rem;
    right: clamp(1.25rem, 5vw, 3rem);
    background: none;
    border: none;
    color: rgba(248, 247, 242, 0.6);
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 0.25rem;
    transition: color 0.2s ease;
  }

  .nav-close:hover {
    color: #fff;
  }

  .nav-overlay-links {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.75rem;
  }

  .nav-overlay-link {
    font-family: 'Syne', sans-serif;
    font-weight: 600;
    font-size: clamp(1.5rem, 5vw, 2rem);
    color: rgba(248, 247, 242, 0.8);
    text-decoration: none;
    letter-spacing: -0.02em;
    transition: color 0.2s ease;
  }

  .nav-overlay-link:hover {
    color: #fff;
  }

  .nav-overlay-cta {
    margin-top: 0.5rem;
  }
</style>

<script>
  const nav      = document.getElementById('site-nav') as HTMLElement;
  const burger   = document.getElementById('nav-burger') as HTMLButtonElement;
  const overlay  = document.getElementById('nav-overlay') as HTMLElement;
  const closeBtn = document.getElementById('nav-close') as HTMLButtonElement;

  // ── Scroll behaviour: scrolled state + hide/show ────────────
  let lastY = window.scrollY;

  window.addEventListener('scroll', () => {
    const y = window.scrollY;

    // Scrolled background
    nav.classList.toggle('is-scrolled', y > 60);

    // Hide on scroll-down past 120px, show on scroll-up
    if (y > 120) {
      if (y > lastY + 8) {
        nav.classList.add('is-hidden');
      } else if (y < lastY - 8) {
        nav.classList.remove('is-hidden');
      }
    } else {
      nav.classList.remove('is-hidden');
    }

    lastY = y;
  }, { passive: true });

  // ── Mobile overlay toggle ────────────────────────────────────
  function openMenu() {
    overlay.classList.add('is-open');
    overlay.setAttribute('aria-hidden', 'false');
    burger.setAttribute('aria-expanded', 'true');
    document.body.classList.add('nav-open');
    closeBtn.focus();
  }

  function closeMenu() {
    overlay.classList.remove('is-open');
    overlay.setAttribute('aria-hidden', 'true');
    burger.setAttribute('aria-expanded', 'false');
    document.body.classList.remove('nav-open');
    burger.focus();
  }

  burger.addEventListener('click', openMenu);
  closeBtn.addEventListener('click', closeMenu);

  // Close on overlay link click
  overlay.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overlay.classList.contains('is-open')) {
      closeMenu();
    }
  });
</script>
