---
/**
 * Process.astro — Section 05, dark.
 * 4 steps: horizontal on desktop, stacked with connector line on mobile.
 */

const steps = [
  {
    number: '01',
    title: 'Discovery & Audit',
    body: 'I start by understanding your business goals and diagnosing your current SEO position — what\'s working, what\'s broken, and where the biggest opportunities are.',
  },
  {
    number: '02',
    title: 'Strategy',
    body: 'A bespoke SEO roadmap aligned to your commercial objectives, prioritised by impact and deliverable in a realistic timeframe.',
  },
  {
    number: '03',
    title: 'Execution',
    body: 'From technical fixes to content and outreach — I handle the work directly. No account managers, no junior team members.',
  },
  {
    number: '04',
    title: 'Reporting & Growth',
    body: 'Regular, clear reporting showing exactly what\'s moving and what it means for your business. Campaigns evolve as the data evolves.',
  },
];
---

<section id="process" class="section-dark section-pad process-section">
  <span class="section-number" aria-hidden="true">05</span>

  <div class="container">
    <div class="process-header reveal">
      <h2 class="process-h2">A process built for results — not retainers</h2>
    </div>

    <div class="process-steps" role="list">
      {steps.map((step, i) => (
        <div class={`process-step reveal reveal-delay-${i + 1}`} role="listitem">
          <!-- Connector line (desktop only, drawn via CSS) -->
          {i < steps.length - 1 && <div class="connector" aria-hidden="true" />}

          <div class="step-number-wrap">
            <span class="step-num" aria-hidden="true">{step.number}</span>
          </div>

          <h3 class="step-title">{step.title}</h3>
          <p class="step-body">{step.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .process-section {
    position: relative;
    overflow: hidden;
  }

  .process-header {
    margin-bottom: 4rem;
    max-width: 680px;
  }

  .process-h2 {
    font-size: clamp(1.875rem, 4vw, 3rem);
    color: #fff;
    margin: 0;
  }

  /* ── Steps layout ────────────────────────────────────────── */
  .process-steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    position: relative;
  }

  @media (min-width: 860px) {
    .process-steps {
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
    }
  }

  /* ── Step ────────────────────────────────────────────────── */
  .process-step {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  @media (min-width: 860px) {
    .process-step {
      padding-right: 2rem;
    }
  }

  /* Mobile connector line (vertical) */
  .process-step:not(:last-child)::after {
    content: '';
    position: absolute;
    left: 19px; /* center of the number circle */
    top: 44px;
    bottom: -3rem;
    width: 1px;
    background: linear-gradient(to bottom, rgba(255,104,38,0.35), transparent);
  }

  @media (min-width: 860px) {
    .process-step:not(:last-child)::after {
      display: none;
    }
  }

  /* Desktop connector line (horizontal) drawn between steps */
  .connector {
    display: none;
  }

  @media (min-width: 860px) {
    .connector {
      display: block;
      position: absolute;
      top: 19px; /* center of number circle */
      left: calc(40px + 1rem); /* after the circle */
      right: 0;
      height: 1px;
      background: linear-gradient(to right, rgba(255,104,38,0.4), rgba(255,255,255,0.08));
    }
  }

  /* Step number circle */
  .step-number-wrap {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid rgba(255, 104, 38, 0.45);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    background-color: rgba(255, 104, 38, 0.08);
  }

  .step-num {
    font-family: 'DM Mono', monospace;
    font-weight: 700;
    font-size: 0.75rem;
    color: var(--accent);
    letter-spacing: 0.04em;
  }

  /* Step content */
  .step-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: #fff;
    letter-spacing: -0.015em;
    margin: 0;
  }

  .step-body {
    font-size: 0.9375rem;
    color: rgba(248, 247, 242, 0.58);
    line-height: 1.68;
  }
</style>
