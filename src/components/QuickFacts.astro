---
interface Fact {
  label: string;
  value: string;
  detail: string;
}

interface Props {
  heading: string;
  subheading?: string;
  facts: Fact[];
}

const { heading, subheading, facts } = Astro.props;
---

<section class="qf-section section-light section-pad">
  <div class="container">

    <div class="qf-header reveal">
      <p class="eyebrow">Local SEO Data</p>
      <h2 class="qf-h2">{heading}</h2>
      {subheading && <p class="qf-sub">{subheading}</p>}
    </div>

    <div class="qf-grid reveal reveal-delay-1">
      {facts.map(f => (
        <div class="qf-card">
          <p class="qf-label">{f.label}</p>
          <p class="qf-value">{f.value}</p>
          <p class="qf-detail">{f.detail}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .qf-section {
    position: relative;
  }

  .qf-header {
    margin-bottom: 2.5rem;
  }

  .qf-h2 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.625rem, 3.5vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin: 0.5rem 0 0;
  }

  .qf-sub {
    font-size: 1rem;
    color: rgba(10, 10, 15, 0.6);
    margin-top: 0.875rem;
    max-width: 56ch;
    line-height: 1.65;
  }

  /* ── Grid ─────────────────────────────────────────────── */
  .qf-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background-color: var(--border-light);
    border: 1px solid var(--border-light);
    border-radius: 0.5rem;
    overflow: hidden;
  }

  @media (min-width: 640px) {
    .qf-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (min-width: 1024px) {
    .qf-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .qf-card {
    background: var(--chalk);
    padding: clamp(1.25rem, 3vw, 1.875rem);
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .qf-label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent-dk);
  }

  .qf-value {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--ink);
    line-height: 1;
    margin: 0.125rem 0;
  }

  .qf-detail {
    font-size: 0.8125rem;
    color: rgba(10, 10, 15, 0.58);
    line-height: 1.55;
  }
</style>
