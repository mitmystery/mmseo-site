<script>
  const PASS = 'mmseo2025';

  function showCV() {
    const gate    = document.getElementById('cv-gate');
    const content = document.getElementById('cv-content');
    if (gate)    gate.style.display    = 'none';
    if (content) content.style.display = 'block';
  }

  function checkAccess() {
    if (sessionStorage.getItem('cv_access') === 'true') {
      showCV();
      return;
    }
    const gate    = document.getElementById('cv-gate');
    const content = document.getElementById('cv-content');
    if (gate)    gate.style.display    = 'flex';
    if (content) content.style.display = 'none';
  }

  function attemptAccess() {
    const input = document.getElementById('cv-password') as HTMLInputElement | null;
    const error = document.getElementById('cv-error');
    if (!input) return;
    if (input.value === PASS) {
      sessionStorage.setItem('cv_access', 'true');
      showCV();
    } else {
      if (error) error.style.display = 'block';
      input.value = '';
      input.focus();
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    checkAccess();

    document.getElementById('cv-submit')?.addEventListener('click', attemptAccess);

    (document.getElementById('cv-password') as HTMLInputElement | null)
      ?.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter') attemptAccess();
      });
  });
</script>
