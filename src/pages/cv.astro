---
/**
 * cv.astro — Password-gated CV page.
 *
 * • Client-side gate: password stored in sessionStorage
 * • noindex, nofollow — must not be indexed
 * • PDF download: /cv.pdf (pre-generated via npm run generate-cv)
 * • Print stylesheet included for browser-print fallback
 */

import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';

const expertise = [
  'SEO strategy', 'Technical SEO', 'Site migrations', 'AI search / GEO',
  'Keyword research', 'Analytics & measurement', 'Tagging & tracking',
  'Content strategy', 'Client leadership', 'GA4', 'GSC', 'Ahrefs',
  'Screaming Frog', 'Sitebulb',
];

const workingStyle = [
  'High ownership', 'Cross-functional collaboration', 'Attention to detail',
  'Structured thinking', 'Mentoring, QA, and delivery leadership',
];

const tools = ['GA4', 'Google Search Console', 'Ahrefs', 'Screaming Frog', 'Sitebulb'];

const caseStudies = [
  {
    client: 'Gulf Oil International',
    sector: 'Global B2C / Lubricants',
    summary: 'Shifted Gulf from heavy brand-search reliance to broad organic visibility. Content strategy built around practical maintenance advice for everyday drivers, backed by technical improvements for global reach.',
    metrics: [
      { value: '+30%',  label: 'YoY organic clicks' },
      { value: '6.1M',  label: 'Total impressions' },
      { value: '+43%',  label: 'Top 3 keyword rankings' },
    ],
  },
  {
    client: 'Witter Towbars',
    sector: 'Automotive / Manufacturing',
    summary: 'Full SEO overhaul covering technical issues, on-page targeting, and a link-building programme. The site went from poor visibility to a consistent source of organic leads.',
    metrics: [
      { value: '+110%', label: 'Organic traffic' },
      { value: '+103%', label: 'Keyword rankings' },
    ],
  },
  {
    client: 'Kingsmead Carpets',
    sector: 'Home / Manufacturing',
    summary: 'SEO was not part of the original site build. Full audit uncovered critical crawlability and structural issues. Rebuilt site architecture from scratch and delivered a clear optimisation roadmap.',
    metrics: [
      { value: '+250%', label: 'Organic traffic' },
      { value: 'Full',  label: 'Architecture rebuild' },
      { value: 'Clear', label: 'Long-term SEO roadmap' },
    ],
  },
  {
    client: 'Number 1 Plates',
    sector: 'Automotive eCommerce',
    summary: 'Technical audit identifying crawl issues and content gaps, followed by a keyword strategy backed by competitor and persona research.',
    metrics: [
      { value: '+95%',   label: 'Organic traffic' },
      { value: '+99.5%', label: 'Revenue growth' },
      { value: 'Top 3',  label: 'Core product keywords' },
    ],
  },
  {
    client: 'Illuminated Mirrors',
    sector: 'eCommerce',
    summary: 'Technical audit, content rewrite around search intent, blog strategy, and targeted link building. Results delivered within the first 6 months.',
    metrics: [
      { value: '+125%', label: 'Organic traffic' },
      { value: '+552%', label: 'Organic revenue' },
      { value: '75+',   label: 'Page 1 rankings' },
    ],
  },
];

const experience = [
  {
    company: 'Senior SEO Manager',
    role: 'Agency (current)',
    dates: 'Sep 2020 – Present',
    bullets: [
      'Lead SEO across a portfolio of high-value accounts, taking strategy through to delivery across technical, content, and authority work.',
      'Delivered measurable growth for clients including Gulf Oil International (+30% YoY clicks, 43% uplift in Top 3 rankings), Witter Towbars (+110% organic traffic), and Kingsmead Carpets (+250% organic traffic following a full architecture rebuild).',
      'Run technical audits and implementation planning; work closely with development and content teams to remove blockers and raise delivery quality.',
      'Manage client relationships, QA standards, and mentoring for junior team members.',
      'Introduced AI search readiness frameworks alongside core SEO delivery, including structured data and content positioning for AI Overviews.',
    ],
  },
  {
    company: 'Powerful Vision Ltd (Illuminated Mirrors)',
    role: 'In-house SEO Manager',
    dates: 'Aug 2018 – Jul 2020',
    bullets: [
      'Moved in-house to Illuminated Mirrors following the agency engagement that had delivered 125% organic traffic growth and 552% revenue uplift.',
      'Owned ongoing SEO strategy end-to-end, working directly with the founders to align search priorities with trading and product objectives.',
      'Managed development, content, and marketing teams to maintain and build on the gains achieved during the agency phase.',
    ],
  },
  {
    company: 'Platform81',
    role: 'SEO Manager',
    dates: 'Aug 2017 – Aug 2018',
    bullets: [],
  },
  {
    company: 'After Digital',
    role: 'SEO Manager',
    dates: 'Sep 2010 – Aug 2017',
    bullets: [
      'Provided high-level SEO consultancy and training across a varied client portfolio, with a particular focus on educational and cultural sectors.',
      'Managed delivery across Manchester and Glasgow teams and acted as a senior point of support on complex accounts.',
      'Developed and implemented the organic strategy for Illuminated Mirrors, delivering a 125% increase in organic traffic and 552% revenue growth within the first 6 months.',
      'Managed broader digital delivery across SEO, paid search, content, and social, while mentoring teams and setting QA standards.',
    ],
  },
  {
    company: 'Just Search',
    role: 'SEO Advisor',
    dates: 'Oct 2009 – Sep 2010',
    bullets: [
      'Served as the technical liaison between account managers and the digital marketing team.',
      'Developed campaign optimisation frameworks and led training for account management teams.',
      'Specialised in troubleshooting and stabilising complex client accounts.',
    ],
  },
  {
    company: 'Firstfound',
    role: 'SEO Consultant',
    dates: 'Nov 2007 – Oct 2009',
    bullets: [
      'Delivered on-page optimisation across a portfolio of client accounts.',
      'Managed white-label agency relationships and supported retention-focused delivery.',
      'Early-career grounding in hands-on SEO execution and account management.',
    ],
  },
];

const year = new Date().getFullYear();
---

<Base
  title="CV — MM SEO | Senior SEO Manager"
  description="MM SEO — Senior SEO Manager. 18 years experience. CV available on request."
  canonical="https://www.mmseo.co.uk/cv/"
  noindex={true}
>
  <Nav />

  <main>

    <!-- ══ PASSWORD GATE ══════════════════════════════════════════════ -->
    <div
      id="cv-gate"
      style="display:none; position:fixed; inset:0; background:#0A0A0F;
             z-index:200; flex-direction:column; align-items:center;
             justify-content:center; gap:1.5rem;"
    >
      <div style="font-family:'Syne',sans-serif; font-weight:800; font-size:1.5rem;
                  color:#fff; letter-spacing:-0.02em;">
        MM<span style="color:#FF6826">SEO</span>
      </div>
      <p style="color:rgba(255,255,255,0.5); font-size:0.9rem; text-align:center;
                max-width:320px; margin:0; font-family:'DM Sans',sans-serif; line-height:1.6;">
        This CV is private. Enter the access code to view.
      </p>
      <div style="display:flex; flex-direction:column; gap:0.75rem; width:100%; max-width:280px;">
        <input
          id="cv-password"
          type="password"
          placeholder="Access code"
          autocomplete="current-password"
          style="background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.15);
                 color:#fff; padding:0.75rem 1rem; font-size:0.95rem; border-radius:2px;
                 width:100%; outline:none; font-family:'DM Sans',sans-serif;"
        />
        <button
          id="cv-submit"
          style="background:#FF6826; color:#fff; border:none; padding:0.75rem 1rem;
                 font-weight:600; font-size:0.9rem; cursor:pointer; border-radius:2px;
                 width:100%; font-family:'DM Sans',sans-serif;"
        >
          Access CV
        </button>
        <p id="cv-error" style="display:none; color:#E24B4A; font-size:0.8rem;
                                text-align:center; margin:0; font-family:'DM Sans',sans-serif;">
          Incorrect code. Please try again.
        </p>
      </div>
    </div>

    <!-- ══ CV CONTENT ════════════════════════════════════════════════ -->
    <div id="cv-content" style="display:none;">

      <!-- ── SECTION 1: Hero (dark) ──────────────────────────────── -->
      <section class="cv-dark-section cv-hero-section">
        <div class="container cv-hero-grid">

          <div class="cv-hero-left">
            <h1 class="cv-name">MM SEO</h1>
            <p class="cv-job-title">Senior SEO Manager</p>
            <p class="cv-subtitle">Technical SEO · Strategy · AI Search · Measurement</p>
            <div class="cv-contact-row">
              <span>📍 Stockport, UK</span>
              <span>✉️ hello@mmseo.co.uk</span>
            </div>
          </div>

          <div class="cv-hero-right">
            <a
              id="download-cv"
              href="/cv.pdf"
              download="MM-SEO-CV.pdf"
              class="btn-primary cv-download-btn"
            >
              ↓ Download PDF
            </a>
          </div>

        </div>
      </section>

      <!-- ── SECTION 2: Stats strip (chalk) ─────────────────────── -->
      <section class="cv-stats-strip">
        <div class="container cv-stats-grid">
          <div class="cv-stat-block">
            <div class="cv-stat-number">18+</div>
            <div class="cv-stat-label">Years in SEO</div>
          </div>
          <div class="cv-stat-block">
            <div class="cv-stat-number">+552%</div>
            <div class="cv-stat-label">Organic revenue · Illuminated Mirrors</div>
          </div>
          <div class="cv-stat-block">
            <div class="cv-stat-number">+250%</div>
            <div class="cv-stat-label">Organic traffic · Kingsmead Carpets</div>
          </div>
          <div class="cv-stat-block">
            <div class="cv-stat-number">+110%</div>
            <div class="cv-stat-label">Organic traffic · Witter Towbars</div>
          </div>
        </div>
      </section>

      <!-- ── SECTION 3: Profile + Expertise (dark) ──────────────── -->
      <section class="cv-dark-section cv-profile-section section-pad">
        <div class="container cv-profile-grid">

          <div class="cv-profile-left">
            <p class="eyebrow">Profile</p>
            <p class="cv-profile-text">
              I've spent the last 18 years working in SEO, mainly across agencies and consultancy, with one in-house role, helping businesses turn organic search into a genuine growth channel rather than just a reporting metric.
            </p>
            <p class="cv-profile-text" style="margin-top:1rem;">
              My work sits where technical, content, and commercial priorities meet. I've led SEO programmes for eCommerce, lead generation, and multi-site brands, often coming into situations where performance has plateaued or the foundations aren't quite right, then working with teams to fix the underlying issues and build something more sustainable. A big part of that is connecting the detail to what actually matters to the business. That means working closely with developers, content teams, and stakeholders so SEO is properly integrated rather than treated as a separate channel. Spending time in-house gave me a clearer view of how that works in practice, across day-to-day trading, internal priorities, and real decision making.
            </p>
            <p class="cv-profile-text" style="margin-top:1rem;">
              More recently, I've been building and shipping products using AI outside of client work: a suite of SEO tools and a published iOS app. It started as a way to test what I could build without an engineering background, but it's made me a more useful person to have in the room when clients are trying to figure out what AI actually means for their search strategy.
            </p>
          </div>

          <div class="cv-profile-right">
            <div class="cv-pill-group">
              <h3 class="cv-pill-heading">Core Expertise</h3>
              <div class="cv-pills">
                {expertise.map(tag => <span class="cv-pill">{tag}</span>)}
              </div>
            </div>
            <div class="cv-pill-group">
              <h3 class="cv-pill-heading">Working Style</h3>
              <div class="cv-pills">
                {workingStyle.map(tag => <span class="cv-pill">{tag}</span>)}
              </div>
            </div>
          </div>

        </div>
      </section>

      <!-- ── SECTION 4: Selected Results (chalk) ────────────────── -->
      <section class="cv-light-section section-pad">
        <div class="container">
          <p class="eyebrow eyebrow-dark">Selected Results</p>
          <div class="cv-results-grid">
            {caseStudies.map(cs => (
              <div class="cv-result-card">
                <div class="cv-result-header">
                  <p class="cv-result-client">{cs.client}</p>
                  <p class="cv-result-sector">{cs.sector}</p>
                </div>
                <p class="cv-result-summary">{cs.summary}</p>
                <div class="cv-result-metrics">
                  {cs.metrics.map(m => (
                    <div class="cv-result-metric">
                      <span class="cv-result-value">{m.value}</span>
                      <span class="cv-result-label">{m.label}</span>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- ── SECTION 5: Experience (dark) ───────────────────────── -->
      <section class="cv-dark-section cv-experience-section section-pad">
        <div class="container">
          <p class="eyebrow">Experience</p>
          <div class="cv-timeline">
            {experience.map((role, i) => (
              <div class="cv-experience-item">
                <div class="cv-role-header">
                  <p class="cv-company">{role.company}</p>
                  <h3 class="cv-role-title">{role.role}</h3>
                  <p class="cv-dates">{role.dates}</p>
                </div>
                {role.bullets.length > 0 && (
                  <ul class="cv-bullets">
                    {role.bullets.map(b => <li>{b}</li>)}
                  </ul>
                )}
                {i < experience.length - 1 && <hr class="cv-rule" />}
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- ── SECTION 6: Building with AI (chalk) ──────────────── -->
      <section class="cv-light-section cv-building-section section-pad">
        <div class="container">

          <p class="eyebrow eyebrow-dark">Beyond Consulting</p>
          <h2 class="cv-building-heading">Building with AI</h2>
          <p class="cv-building-intro">
            Alongside client work, I've spent the past year building with AI to see what's actually possible as a practitioner with domain knowledge but no engineering background. A suite of SEO tools and a published iOS app, both built using Claude Code and shipped to real users.
          </p>

          <!-- SUB-SECTION: SEO Tools Suite -->
          <h3 class="cv-sub-heading">SEO Tools Suite</h3>
          <p class="cv-sub-intro">Seven browser-based SEO tools built with Claude Code, each solving a workflow problem I kept running into.</p>

          <div class="cv-tools-grid">
            <div class="cv-tool-card">
              <span class="cv-tool-category cv-tool-category--onpage">On-Page</span>
              <p class="cv-tool-name">Internal Linking Finder</p>
              <p class="cv-tool-desc">Discovers internal linking opportunities across a site to strengthen topical authority and improve crawlability.</p>
            </div>
            <div class="cv-tool-card">
              <span class="cv-tool-category cv-tool-category--technical">Technical</span>
              <p class="cv-tool-name">URL Status Checker</p>
              <p class="cv-tool-desc">Bulk-checks HTTP status codes and redirect chains for any list of URLs, fast and without leaving the browser.</p>
            </div>
            <div class="cv-tool-card">
              <span class="cv-tool-category cv-tool-category--onpage">On-Page</span>
              <p class="cv-tool-name">Schema Opportunity Finder</p>
              <p class="cv-tool-desc">Identifies missing structured data opportunities on any page to boost rich-result eligibility in search.</p>
            </div>
            <div class="cv-tool-card">
              <span class="cv-tool-category cv-tool-category--technical">Technical</span>
              <p class="cv-tool-name">GTM Inspector</p>
              <p class="cv-tool-desc">Inspects tags, triggers, and variables firing on any URL to audit Google Tag Manager setups.</p>
            </div>
            <div class="cv-tool-card">
              <span class="cv-tool-category cv-tool-category--research">Research</span>
              <p class="cv-tool-name">Keyword Cluster</p>
              <p class="cv-tool-desc">Groups keyword lists into semantic clusters automatically, making content planning faster and more strategic.</p>
            </div>
            <div class="cv-tool-card">
              <span class="cv-tool-category cv-tool-category--technical">Technical</span>
              <p class="cv-tool-name">Robots.txt Validator</p>
              <p class="cv-tool-desc">Validates robots.txt files, checks syntax, tests URL matching, and flags crawl-blocking mistakes.</p>
            </div>
            <div class="cv-tool-card">
              <span class="cv-tool-category cv-tool-category--technical">Technical</span>
              <p class="cv-tool-name">AI Bot Access Tester</p>
              <p class="cv-tool-desc">Tests whether AI crawlers can access a site by checking bot permissions and user-agent rules.</p>
            </div>
          </div>

          <p class="cv-tools-note">All tools built using Claude Code. No prior software engineering background.</p>

          <!-- Divider -->
          <hr class="cv-building-rule" />

          <!-- SUB-SECTION: iOS App -->
          <h3 class="cv-sub-heading">iOS App: Exercise Snacks</h3>

          <div class="cv-app-card">
            <div class="cv-app-left">
              <span class="cv-tool-category cv-tool-category--app">App Store · iOS</span>
              <p class="cv-app-title">Exercise Snacks: Desk Breaks</p>
              <p class="cv-app-body">
                An iOS app that prompts office workers to take short movement breaks at regular intervals throughout the day. Based on research (Gao et al., 2024) showing brief bouts of bodyweight exercise reduce postprandial blood glucose by 21%, comparable to frequent walking breaks.
              </p>
              <p class="cv-app-body" style="margin-top:0.75rem;">
                30 guided exercises with custom Lottie animations, three notification modes, streak tracking, and a gentle gamification system. Built to see how far Claude Code could take a non-engineer with strong domain knowledge.
              </p>
              <p class="cv-app-tech">Built with Expo / React Native using Claude Code. Designed, developed, and published independently.</p>
            </div>
            <div class="cv-app-right">
              <div class="cv-app-stats">
                <div class="cv-app-stat">
                  <span class="cv-app-stat-value">30</span>
                  <span class="cv-app-stat-label">Guided exercises</span>
                </div>
                <div class="cv-app-stat">
                  <span class="cv-app-stat-value">21%</span>
                  <span class="cv-app-stat-label">Blood glucose reduction (clinical evidence)</span>
                </div>
                <div class="cv-app-stat">
                  <span class="cv-app-stat-value">3</span>
                  <span class="cv-app-stat-label">Notification modes</span>
                </div>
                <div class="cv-app-stat">
                  <span class="cv-app-stat-value">£49.99</span>
                  <span class="cv-app-stat-label">Premium annual subscription</span>
                </div>
              </div>
              <p class="cv-app-store-note">Available on the Apple App Store</p>
            </div>
          </div>

          <!-- Closing sentence -->
          <p class="cv-building-close">
            Not just advising clients on AI and search, but actually building with it.
          </p>

        </div>
      </section>

      <!-- ── SECTION 7: Education + Tools (chalk) ───────────────── -->
      <section class="cv-light-section section-pad">
        <div class="container cv-edu-grid">

          <div class="cv-edu-left">
            <h3 class="cv-edu-heading">Education</h3>
            <p class="cv-edu-degree">BSc Multimedia Technology (2:2)</p>
            <p class="cv-edu-uni">University of Huddersfield, 2003–2006</p>
          </div>

          <div class="cv-edu-right">
            <h3 class="cv-edu-heading">Tools</h3>
            <div class="cv-pills">
              {tools.map(t => <span class="cv-pill cv-pill-light">{t}</span>)}
            </div>
          </div>

        </div>
      </section>

      <!-- ── Minimal CV footer ───────────────────────────────────── -->
      <footer class="cv-footer cv-dark-section">
        <div class="container">
          <p class="cv-footer-copy">&copy; {year} MM SEO</p>
        </div>
      </footer>

    </div>
    <!-- /#cv-content -->

  </main>

</Base>

<style>
  /* ── Hero ─────────────────────────────────────────────────────────── */
  .cv-hero-section {
    padding-top: calc(68px + clamp(3rem, 6vw, 5rem));
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }

  .cv-hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: start;
  }

  @media (min-width: 768px) {
    .cv-hero-grid {
      grid-template-columns: 1fr auto;
      align-items: center;
    }
  }

  .cv-name {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: clamp(2rem, 5vw, 3rem);
    color: #fff;
    letter-spacing: -0.03em;
    line-height: 1.08;
    margin-bottom: 0.5rem;
  }

  .cv-job-title {
    font-family: 'Syne', sans-serif;
    font-weight: 600;
    font-size: clamp(1.125rem, 2.5vw, 1.5rem);
    color: #FF6826;
    margin-bottom: 0.5rem;
    line-height: 1.2;
  }

  .cv-subtitle {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    color: rgba(248, 247, 242, 0.5);
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
  }

  .cv-contact-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 1.25rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    color: rgba(248, 247, 242, 0.5);
  }

  .cv-hero-right {
    display: flex;
    justify-content: flex-start;
  }

  @media (min-width: 768px) {
    .cv-hero-right {
      justify-content: flex-end;
      align-items: center;
    }
  }

  .cv-download-btn {
    font-size: 0.875rem;
    padding: 0.75rem 1.5rem;
    border-radius: 2px;
    white-space: nowrap;
  }

  /* ── Stats strip ──────────────────────────────────────────────────── */
  .cv-stats-strip {
    background-color: var(--chalk);
    color: var(--ink);
    padding-block: clamp(2.5rem, 5vw, 4rem);
  }

  .cv-stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem 1.5rem;
  }

  @media (min-width: 640px) {
    .cv-stats-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }
  }

  .cv-stat-block {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .cv-stat-number {
    font-family: 'DM Mono', monospace;
    font-weight: 700;
    font-size: clamp(2.25rem, 4.5vw, 3.25rem);
    line-height: 1;
    color: var(--accent-dk);
    letter-spacing: -0.02em;
  }

  .cv-stat-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--muted);
    line-height: 1.4;
  }

  /* ── Profile section ──────────────────────────────────────────────── */
  .cv-profile-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 900px) {
    .cv-profile-grid {
      grid-template-columns: 5fr 4fr;
      gap: 4rem;
    }
  }

  .cv-profile-text {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(1rem, 1.3vw, 1.0625rem);
    color: rgba(248, 247, 242, 0.75);
    line-height: 1.8;
    max-width: 60ch;
    margin-top: 0.75rem;
  }

  .cv-pill-group {
    margin-bottom: 2rem;
  }

  .cv-pill-group:last-child {
    margin-bottom: 0;
  }

  .cv-pill-heading {
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
    font-size: 0.72rem;
    color: rgba(248, 247, 242, 0.45);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .cv-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .cv-pill {
    display: inline-block;
    padding: 0.3rem 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 2rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    color: rgba(248, 247, 242, 0.8);
    white-space: nowrap;
    line-height: 1.5;
  }

  .cv-pill-light {
    border-color: rgba(10, 10, 15, 0.2);
    color: rgba(10, 10, 15, 0.7);
  }

  /* ── Eyebrow on light background ─────────────────────────────────── */
  .eyebrow-dark {
    color: var(--accent-dk);
  }

  /* ── Selected Results ─────────────────────────────────────────────── */
  .cv-results-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
