---
import Base       from '../layouts/Base.astro';
import Nav        from '../components/Nav.astro';
import Footer     from '../components/Footer.astro';
import Hero       from '../components/Hero.astro';
import Stats      from '../components/Stats.astro';
import Services   from '../components/Services.astro';
import Results    from '../components/Results.astro';
import Process    from '../components/Process.astro';
import Sectors    from '../components/Sectors.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ        from '../components/FAQ.astro';
import ContactForm from '../components/ContactForm.astro';

const homepageSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': ['LocalBusiness', 'ProfessionalService'],
      '@id': 'https://www.mmseo.co.uk/#business',
      'name': 'MM SEO',
      'description': 'Freelance SEO consultancy. Technical SEO, strategy, keyword research, on-page SEO, link building, and local SEO for businesses across Manchester, Stockport and the UK.',
      'url': 'https://www.mmseo.co.uk/',
      'telephone': '+447886315620',
      'email': 'mithul.mistry@gmail.com',
      'address': {
        '@type': 'PostalAddress',
        'addressLocality': 'Marple',
        'addressRegion': 'Stockport',
        'addressCountry': 'GB',
      },
      'geo': {
        '@type': 'GeoCoordinates',
        'latitude': '53.4014',
        'longitude': '-2.0593',
      },
      'areaServed': [
        { '@type': 'City',    'name': 'Manchester' },
        { '@type': 'City',    'name': 'Stockport' },
        { '@type': 'Country', 'name': 'United Kingdom' },
      ],
      'sameAs': ['https://www.linkedin.com/in/mithul-mistry/'],
      'founder': { '@id': 'https://www.mmseo.co.uk/#person' },
    },
    {
      '@type': 'Person',
      '@id': 'https://www.mmseo.co.uk/#person',
      'name': 'Mithul Mistry',
      'jobTitle': 'Freelance SEO Consultant',
      'url': 'https://www.mmseo.co.uk/',
      'image': 'https://www.mmseo.co.uk/mithul-mistry.jpg',
      'sameAs': 'https://www.linkedin.com/in/mithul-mistry/',
      'worksFor': { '@id': 'https://www.mmseo.co.uk/#business' },
      'knowsAbout': [
        'SEO', 'Technical SEO', 'Keyword Research', 'Link Building',
        'Local SEO', 'Google Analytics 4', 'Google Search Console',
        'Screaming Frog', 'Ahrefs',
      ],
    },
    {
      '@type': 'FAQPage',
      'mainEntity': [
        {
          '@type': 'Question',
          'name': 'How long does SEO take to show results?',
          'acceptedAnswer': {
            '@type': 'Answer',
            'text': "Most campaigns begin showing meaningful movement in 3–6 months. Highly competitive keywords can take 9–12 months. I'll give you an honest, realistic timeline in our initial consultation — not the promises you'll sometimes get elsewhere.",
          },
        },
        {
          '@type': 'Question',
          'name': 'Why hire a freelance SEO consultant instead of an agency?',
          'acceptedAnswer': {
            '@type': 'Answer',
            'text': "You get direct access to the person doing the work. No junior account managers, no inflated overheads, no being deprioritised when a bigger client comes along. For most SMEs, a specialist freelancer delivers better results for less money than a mid-tier agency.",
          },
        },
        {
          '@type': 'Question',
          'name': 'Do you work with clients outside Manchester and Stockport?',
          'acceptedAnswer': {
            '@type': 'Answer',
            'text': "Yes — I work with clients across the UK. While based in Marple, Stockport, the majority of my work is remote. I have clients from London to Edinburgh.",
          },
        },
        {
          '@type': 'Question',
          'name': 'What industries do you specialise in?',
          'acceptedAnswer': {
            '@type': 'Answer',
            'text': "I've delivered results across eCommerce, legal services, hospitality, financial services, professional services, and more. If your customers use Google to find businesses like yours, SEO can work for you.",
          },
        },
        {
          '@type': 'Question',
          'name': 'Do you offer one-off SEO audits?',
          'acceptedAnswer': {
            '@type': 'Answer',
            'text': "Yes. A standalone technical SEO audit is a great entry point if you're not ready for an ongoing retainer. You'll receive a prioritised action plan you can act on immediately — with me or in-house.",
          },
        },
        {
          '@type': 'Question',
          'name': 'How do you report on progress?',
          'acceptedAnswer': {
            '@type': 'Answer',
            'text': "You'll receive monthly reports covering rankings, organic traffic, and the commercial outcomes that matter. No vanity metrics — just the numbers that reflect real growth.",
          },
        },
      ],
    },
  ],
};
---

<Base
  title="Freelance SEO Consultant Manchester & Stockport | MM SEO"
  description="Mithul Mistry — freelance SEO consultant with 18 years experience. Helping businesses across Manchester & Stockport rank higher, get found, and grow. Book a free consultation."
  schema={homepageSchema}
>
  <Nav />

  <main id="main-content">
    <Hero />
    <Stats />
    <Services />
    <Results />
    <Process />
    <Sectors />
    <Testimonials />
    <FAQ />
    <ContactForm />
  </main>

  <Footer />
</Base>
