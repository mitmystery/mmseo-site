---
import ServicePage from '../layouts/ServicePage.astro';
import ContactForm from '../components/ContactForm.astro';
---

<script type="application/ld+json" is:inline>{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How does SEO help estate agents get more leads?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "SEO helps estate agents appear when buyers and sellers search for agents in their area — 'estate agents in Manchester', 'sell my house Stockport', 'letting agents near me'. Ranking on page one for these high-intent searches generates a consistent stream of qualified enquiries without paying for each click."
      }
    },
    {
      "@type": "Question",
      "name": "What SEO tactics work best for estate agents?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The highest-impact tactics for estate agents are local SEO (Google Business Profile, local citations, and area-specific landing pages), on-page optimisation for location and property-type keywords, and content that captures buyers and sellers at different stages of their journey — area guides, property market reports, and first-time buyer resources."
      }
    },
    {
      "@type": "Question",
      "name": "How long does SEO take to work for estate agents?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Google Business Profile improvements and local citation work can produce results within 4–8 weeks. Organic keyword rankings typically improve meaningfully within 3–6 months of consistent effort. The timeline depends on the competitiveness of your area and how well-optimised your site currently is."
      }
    },
    {
      "@type": "Question",
      "name": "Do you work with independent estate agents or only large agencies?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "I work with both. Independent estate agents and smaller regional agencies often benefit most from SEO because it levels the playing field against the major portals and national chains. A well-executed local SEO strategy can put a single-branch independent agent ahead of a large chain for searches in their specific area."
      }
    }
  ]
}</script>

<ServicePage
  title="SEO for Estate Agents | Real Estate SEO Consultant | MM SEO"
  description="Freelance SEO consultant for estate agents. Get found when buyers and sellers search locally. Local SEO, Google Maps, area pages. Manchester, Stockport & UK."
  canonical="https://www.mmseo.co.uk/seo-services-for-estate-agents/"
  breadcrumb="SEO for Estate Agents"
>

  <!-- ── 1. Hero band (dark) ─────────────────────────────────── -->
  <section class="sp-hero section-dark">
    <div class="container sp-hero-inner reveal">
      <p class="eyebrow">SEO for Estate Agents | Manchester, Stockport &amp; UK</p>
      <h1 class="sp-h1">SEO for Estate Agents: Get Found When Buyers and Sellers Search</h1>
      <p class="sp-intro">
        The property market runs on local search. When someone decides to sell their home or
        find a letting agent, their first move is Google. I help estate agents appear at the
        top of those searches — and turn that visibility into enquiries.
      </p>
      <a href="/#contact" class="btn-primary">Book a Free Consultation</a>
    </div>
  </section>

  <!-- ── 2. What I do (light) ──────────────────────────────────── -->
  <section class="sp-content section-light">
    <div class="container sp-content-inner reveal">
      <h2 class="sp-h2">SEO Services for Estate Agents</h2>
      <p>
        Estate agency is one of the most location-dependent businesses there is. Your
        clients are almost always within a specific geographic area, and their searches
        reflect that: "estate agents Manchester", "letting agents Stockport", "sell my
        house Altrincham". Ranking for these searches is where estate agent SEO delivers
        its value.
      </p>
      <p>
        I work with estate agents and letting agencies across Greater Manchester and the UK
        to build the kind of local search presence that generates a consistent flow of
        buyer, seller, and landlord enquiries.
      </p>

      <h3 class="sp-h3">What I cover</h3>
      <ul class="sp-list">
        <li><strong>Google Business Profile optimisation</strong>: your GBP is the first thing a local searcher sees — I optimise every element to maximise Map Pack visibility for your core location and surrounding areas</li>
        <li><strong>Local citation building</strong>: consistent Name, Address, Phone across all major UK directories and property-specific platforms to build local ranking signals</li>
        <li><strong>Area landing pages</strong>: dedicated, well-optimised pages for each town or neighbourhood you cover — essential for ranking beyond your primary location</li>
        <li><strong>On-page SEO</strong>: title tags, meta descriptions, H1s and page content optimised for the exact terms your buyers and sellers use</li>
        <li><strong>Content strategy</strong>: area guides, market reports, and advice content that attracts organic traffic at every stage of the property journey</li>
        <li><strong>Technical SEO</strong>: site speed, mobile usability, structured data, and crawlability — the foundations that support everything else</li>
        <li><strong>Review strategy</strong>: more Google reviews, handled correctly, directly improve your Map Pack position and click-through rate</li>
        <li><strong>Competitor analysis</strong>: understanding exactly what the agents above you are doing and identifying the gaps I can close for you</li>
      </ul>
    </div>
  </section>

  <!-- ── 3. Why estate agents need specialist SEO (dark) ─────── -->
  <section class="sp-why section-dark">
    <div class="container sp-why-inner reveal">
      <h2 class="sp-h2 chalk">Why Estate Agent SEO Is Different</h2>
      <p class="chalk-muted">
        Property portals like Rightmove and Zoopla dominate national property searches —
        and trying to outrank them for generic terms is not a winnable strategy for most
        independent agents. Estate agent SEO works differently: it focuses on the searches
        where you can win. "Estate agents [town]", "sell my house [area]", "letting agents
        near [location]" — these are the queries where a well-optimised local agent can
        outrank a national portal that doesn't serve that specific area.
      </p>
      <p class="chalk-muted">
        The Map Pack is particularly valuable for estate agents. When a seller types "estate
        agents near me", the three Google Business Profile listings that appear above the
        organic results capture a significant share of clicks. Getting into that Map Pack
        for your target location is often the single highest-impact SEO action available
        to a local agent.
      </p>
      <p class="chalk-muted">
        I understand the property market and how buyers, sellers, landlords, and tenants
        search. That context shapes the strategy — so we're always optimising for the
        searches that actually drive enquiries, not just traffic.
      </p>
    </div>
  </section>

  <!-- ── 4. Local angle (light) ────────────────────────────────── -->
  <section class="sp-content section-light">
    <div class="container sp-content-inner reveal">
      <h2 class="sp-h2">Estate Agent SEO in Manchester and Stockport</h2>
      <p>
        Greater Manchester is one of the most competitive property markets outside London.
        Estate agents in Manchester city centre, Stockport, Altrincham, Sale, Didsbury, and
        surrounding areas are competing for a limited pool of vendor and landlord instructions.
        Local SEO is one of the most cost-effective ways to gain an edge over competitors in
        your specific patch.
      </p>
      <p>
        I'm based in Stockport and have a strong understanding of the Greater Manchester
        property market and the local search landscape. Whether you're an independent agent
        in Stockport looking to dominate your local area or a multi-branch agency across
        Greater Manchester, I build SEO strategies around your specific locations and
        target clients.
      </p>
      <p>
        For estate agents outside Greater Manchester, I work remotely across the UK.
        Local SEO is highly effective regardless of geography — the principles are the
        same, and the strategy is always built around your specific locations and
        competitive landscape.
      </p>
    </div>
  </section>

  <!-- ── 5. FAQ (light) ──────────────────────────────────────── -->
  <section class="sp-content section-light">
    <div class="container sp-content-inner reveal">
      <h2 class="sp-h2">Frequently Asked Questions</h2>

      <dl class="page-faq-list">

        <div class="page-faq-item">
          <dt>
            <button class="page-faq-trigger" aria-expanded="false" aria-controls="pfaq-0" id="pfaq-btn-0">
              <span class="page-faq-question">How does SEO help estate agents get more leads?</span>
              <span class="page-faq-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <line x1="12" y1="5" x2="12" y2="19" class="pfaq-icon-v"/>
                  <line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
              </span>
            </button>
          </dt>
          <dd id="pfaq-0" class="page-faq-answer" role="region" aria-labelledby="pfaq-btn-0" hidden>
            <div class="page-faq-answer-inner">
              <p>SEO helps estate agents appear when buyers and sellers search for agents in their area — "estate agents in Manchester", "sell my house Stockport", "letting agents near me". Ranking on page one for these high-intent searches generates a consistent stream of qualified enquiries without paying for each click.</p>
            </div>
          </dd>
        </div>

        <div class="page-faq-item">
          <dt>
            <button class="page-faq-trigger" aria-expanded="false" aria-controls="pfaq-1" id="pfaq-btn-1">
              <span class="page-faq-question">What SEO tactics work best for estate agents?</span>
              <span class="page-faq-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <line x1="12" y1="5" x2="12" y2="19" class="pfaq-icon-v"/>
                  <line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
              </span>
            </button>
          </dt>
          <dd id="pfaq-1" class="page-faq-answer" role="region" aria-labelledby="pfaq-btn-1" hidden>
            <div class="page-faq-answer-inner">
              <p>The highest-impact tactics for estate agents are local SEO (Google Business Profile, local citations, and area-specific landing pages), on-page optimisation for location and property-type keywords, and content that captures buyers and sellers at different stages — area guides, property market reports, and first-time buyer resources.</p>
            </div>
          </dd>
        </div>

        <div class="page-faq-item">
          <dt>
            <button class="page-faq-trigger" aria-expanded="false" aria-controls="pfaq-2" id="pfaq-btn-2">
              <span class="page-faq-question">How long does SEO take to work for estate agents?</span>
              <span class="page-faq-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <line x1="12" y1="5" x2="12" y2="19" class="pfaq-icon-v"/>
                  <line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
              </span>
            </button>
          </dt>
          <dd id="pfaq-2" class="page-faq-answer" role="region" aria-labelledby="pfaq-btn-2" hidden>
            <div class="page-faq-answer-inner">
              <p>Google Business Profile improvements and local citation work can produce results within 4–8 weeks. Organic keyword rankings typically improve meaningfully within 3–6 months of consistent effort. The timeline depends on the competitiveness of your area and how well-optimised your site currently is.</p>
            </div>
          </dd>
        </div>

        <div class="page-faq-item">
          <dt>
            <button class="page-faq-trigger" aria-expanded="false" aria-controls="pfaq-3" id="pfaq-btn-3">
              <span class="page-faq-question">Do you work with independent estate agents or only large agencies?</span>
              <span class="page-faq-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <line x1="12" y1="5" x2="12" y2="19" class="pfaq-icon-v"/>
                  <line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
              </span>
            </button>
          </dt>
          <dd id="pfaq-3" class="page-faq-answer" role="region" aria-labelledby="pfaq-btn-3" hidden>
            <div class="page-faq-answer-inner">
              <p>I work with both. Independent estate agents and smaller regional agencies often benefit most from SEO because it levels the playing field against the major portals and national chains. A well-executed local SEO strategy can put a single-branch independent agent ahead of a large chain for searches in their specific area.</p>
            </div>
          </dd>
        </div>

      </dl>
    </div>
  </section>

  <!-- ── 6. Contact CTA ───────────────────────────────────────── -->
  <ContactForm />

</ServicePage>

<style>
  .section-dark  { background-color: var(--ink);  color: var(--chalk); }
  .section-light { background-color: var(--chalk); color: var(--ink); }

  .container {
    max-width: 860px;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 5vw, 2rem);
  }

  .sp-hero { padding: 5rem 0 4rem; }
  .sp-hero-inner { display: flex; flex-direction: column; gap: 1.5rem; }

  .eyebrow {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0;
  }

  .sp-h1 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--chalk);
    margin: 0;
  }

  .sp-intro {
    font-size: 1.125rem;
    line-height: 1.7;
    color: rgba(248, 247, 242, 0.75);
    max-width: 640px;
  }

  .btn-primary {
    display: inline-block;
    background-color: var(--accent);
    color: #fff;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    font-weight: 500;
    padding: 0.8rem 1.75rem;
    border-radius: 4px;
    transition: background-color 0.2s ease;
    align-self: flex-start;
  }
  .btn-primary:hover { background-color: var(--accent-dk); }

  .sp-content { padding: 4rem 0; }
  .sp-content-inner { display: flex; flex-direction: column; gap: 1.5rem; }

  .sp-h2 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin: 0;
  }
  .sp-h2.chalk { color: var(--chalk); }

  .sp-h3 {
    font-family: 'Syne', sans-serif;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--ink);
    margin: 0.5rem 0 0;
  }

  .sp-content p, .sp-content-inner p {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: rgba(10, 10, 15, 0.8);
  }

  .sp-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .sp-list li {
    font-size: 1rem;
    line-height: 1.65;
    padding-left: 1.25rem;
    position: relative;
    color: rgba(10, 10, 15, 0.8);
  }
  .sp-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-size: 0.875rem;
  }

  .sp-why { padding: 4rem 0; }
  .sp-why-inner { display: flex; flex-direction: column; gap: 1.5rem; }
  .chalk { color: var(--chalk); }
  .chalk-muted {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: rgba(248, 247, 242, 0.75);
  }

  /* ── Page FAQ ────────────────────────────────────────────────── */
  .page-faq-list { margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0; }
  .page-faq-item { border-bottom: 1px solid var(--border-light); }
  .page-faq-item:first-child { border-top: 1px solid var(--border-light); }
  .page-faq-trigger {
    width: 100%; background: none; border: none; padding: 1.375rem 0;
    display: flex; align-items: center; justify-content: space-between;
    gap: 1.5rem; cursor: pointer; text-align: left;
  }
  .page-faq-question {
    font-family: 'Syne', sans-serif; font-weight: 600;
    font-size: clamp(0.9375rem, 1.2vw, 1.0625rem);
    color: var(--ink); line-height: 1.4; letter-spacing: -0.01em;
  }
  .page-faq-icon {
    flex-shrink: 0; width: 32px; height: 32px; border-radius: 50%;
    border: 1px solid var(--border-light); display: flex;
    align-items: center; justify-content: center; color: var(--accent-dk);
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }
  .page-faq-trigger:hover .page-faq-icon {
    background-color: rgba(10, 10, 15, 0.04); border-color: rgba(10, 10, 15, 0.2);
  }
  .pfaq-icon-v { transition: transform 0.25s ease, opacity 0.25s ease; transform-origin: center; }
  .page-faq-trigger[aria-expanded="true"] .pfaq-icon-v { transform: rotate(90deg); opacity: 0; }
  .page-faq-answer-inner { padding-bottom: 1.375rem; }
  .page-faq-answer-inner p {
    font-size: clamp(0.9375rem, 1.2vw, 1.0625rem);
    color: rgba(10, 10, 15, 0.7); line-height: 1.75; max-width: 65ch;
  }

  .reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.55s ease, transform 0.55s ease; }
  .reveal.visible { opacity: 1; transform: none; }
</style>

<script>
  const revealEls = document.querySelectorAll('.reveal');
  const io = new IntersectionObserver(
    (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); } }),
    { threshold: 0.12 }
  );
  revealEls.forEach(el => io.observe(el));

  const pageFaqTriggers = document.querySelectorAll<HTMLButtonElement>('.page-faq-trigger');
  pageFaqTriggers.forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const expanded = trigger.getAttribute('aria-expanded') === 'true';
      const answerId = trigger.getAttribute('aria-controls')!;
      const answer = document.getElementById(answerId)!;
      pageFaqTriggers.forEach((t) => {
        if (t !== trigger) {
          t.setAttribute('aria-expanded', 'false');
          document.getElementById(t.getAttribute('aria-controls')!)!.hidden = true;
        }
      });
      trigger.setAttribute('aria-expanded', expanded ? 'false' : 'true');
      answer.hidden = expanded;
    });
  });
</script>
