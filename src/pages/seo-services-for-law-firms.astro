---
import ServicePage from '../layouts/ServicePage.astro';
import ContactForm from '../components/ContactForm.astro';
---

<script type="application/ld+json" is:inline>{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Why do law firms need SEO?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most people searching for legal advice start with Google. Queries like 'family solicitor Manchester', 'employment law advice Stockport', or 'conveyancing solicitor near me' are high-intent searches from people who need a lawyer right now. Ranking for these terms generates a consistent flow of qualified client enquiries without the cost of paid advertising."
      }
    },
    {
      "@type": "Question",
      "name": "What SEO tactics work best for law firms?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The most effective tactics for law firms are: dedicated practice area pages optimised for each legal service, local SEO for location-based queries, Google Business Profile optimisation, high-quality content that answers the questions potential clients are searching for, and link building from legal directories and authoritative sources. E-E-A-T (Experience, Expertise, Authoritativeness, Trustworthiness) signals matter particularly for legal content."
      }
    },
    {
      "@type": "Question",
      "name": "Is SEO better than paid ads (PPC) for law firms?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Legal PPC keywords are among the most expensive in any industry — clicks for 'personal injury solicitor' or 'divorce lawyer' can cost £20–£50 each. SEO requires more upfront investment in time and content but produces traffic that doesn't stop when you turn off the budget. Most law firms benefit from both, but SEO builds a durable asset that pays off over years."
      }
    },
    {
      "@type": "Question",
      "name": "How do you handle YMYL (Your Money or Your Life) content for legal sites?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Legal content falls into Google's YMYL category, meaning it's held to a higher standard for accuracy, expertise, and trustworthiness. I ensure all content is reviewed for factual accuracy, attributes expertise clearly, includes appropriate disclaimers, and is structured to demonstrate E-E-A-T signals. Author credentials and firm background are incorporated into the content strategy."
      }
    }
  ]
}</script>

<ServicePage
  title="SEO for Law Firms | Law Firm SEO Consultant | MM SEO"
  description="Freelance SEO consultant for law firms and solicitors. Rank for practice area and local search queries. Manchester, Stockport & UK. Free consultation."
  canonical="https://www.mmseo.co.uk/seo-services-for-law-firms/"
  breadcrumb="SEO for Law Firms"
>

  <!-- ── 1. Hero band (dark) ─────────────────────────────────── -->
  <section class="sp-hero section-dark">
    <div class="container sp-hero-inner reveal">
      <p class="eyebrow">Law Firm SEO Consultant | Manchester, Stockport &amp; UK</p>
      <h1 class="sp-h1">SEO for Law Firms: Rank for the Clients Who Need You Most</h1>
      <p class="sp-intro">
        When someone needs a solicitor, they search Google first. I help law firms and
        legal practices rank for the practice area and location searches that bring in
        qualified client enquiries — sustainably, without relying on paid advertising.
      </p>
      <a href="/#contact" class="btn-primary">Book a Free Consultation</a>
    </div>
  </section>

  <!-- ── 2. What I do (light) ──────────────────────────────────── -->
  <section class="sp-content section-light">
    <div class="container sp-content-inner reveal">
      <h2 class="sp-h2">SEO Services for Law Firms and Solicitors</h2>
      <p>
        Legal SEO sits at the intersection of local search, content authority, and
        technical precision. A firm ranking well for "employment solicitor Manchester"
        or "family law Stockport" is capturing clients at the exact moment they need
        legal help — searches with high commercial intent and low tolerance for being
        on page two.
      </p>
      <p>
        I work with solicitors, barristers, legal consultancies, and multi-practice law
        firms to build search visibility that drives client enquiries. Every strategy
        is built around your specific practice areas, your geography, and the clients
        you want to attract.
      </p>

      <h3 class="sp-h3">What I cover</h3>
      <ul class="sp-list">
        <li><strong>Practice area page optimisation</strong>: dedicated, well-optimised pages for each service (family law, employment, conveyancing, etc.) — the foundation of law firm SEO</li>
        <li><strong>Local SEO</strong>: Google Business Profile, local citations, and geo-targeted content to rank for "[practice area] [location]" searches</li>
        <li><strong>Legal content strategy</strong>: well-researched, accurate content that answers the questions your potential clients are searching — blog posts, guides, FAQs, and explainers that demonstrate expertise</li>
        <li><strong>E-E-A-T signals</strong>: structuring your site to clearly demonstrate Experience, Expertise, Authoritativeness, and Trustworthiness — critical for YMYL legal content</li>
        <li><strong>Technical SEO</strong>: site architecture, crawlability, Core Web Vitals, and schema markup (including LegalService schema)</li>
        <li><strong>Link building</strong>: acquiring links from legal directories, local business sites, and authoritative sources in your practice areas</li>
        <li><strong>Competitor analysis</strong>: identifying what competing firms rank for and where the ranking opportunities are</li>
      </ul>
    </div>
  </section>

  <!-- ── 3. Why legal SEO is different (dark) ──────────────────── -->
  <section class="sp-why section-dark">
    <div class="container sp-why-inner reveal">
      <h2 class="sp-h2 chalk">Why Law Firm SEO Requires a Specialist Approach</h2>
      <p class="chalk-muted">
        Legal content is classified by Google as YMYL — Your Money or Your Life. This
        means Google applies a higher standard of scrutiny to legal websites: accuracy,
        expertise, and trustworthiness matter more here than in almost any other sector.
        A law firm SEO strategy that ignores E-E-A-T signals will struggle regardless
        of how technically well-optimised the site is.
      </p>
      <p class="chalk-muted">
        Legal PPC is among the most expensive advertising in any industry. Clicks for
        "personal injury solicitor" or "divorce lawyer" can cost £20–£50 each, and the
        competition is fierce. SEO builds a durable traffic asset that compounds over time
        — and doesn't stop working when you turn off the budget.
      </p>
      <p class="chalk-muted">
        I understand the specific requirements of legal content — appropriate disclaimers,
        attribution of expertise, and the balance between being helpful to searchers and
        compliant with Solicitors Regulation Authority guidelines on legal marketing.
      </p>
    </div>
  </section>

  <!-- ── 4. Local angle (light) ────────────────────────────────── -->
  <section class="sp-content section-light">
    <div class="container sp-content-inner reveal">
      <h2 class="sp-h2">Law Firm SEO in Manchester and Stockport</h2>
      <p>
        Greater Manchester has a highly competitive legal market. Law firms in Manchester
        city centre, Stockport, Altrincham, Salford, and across the region are competing
        for the same high-value searches. For solicitors specialising in family law,
        employment, personal injury, conveyancing, or commercial law, local search
        visibility is a direct line to new clients.
      </p>
      <p>
        I work with law firms across Greater Manchester and the UK, building SEO
        strategies tailored to your practice areas and your local market. Whether you're
        a sole practitioner or a multi-partner firm, the approach is always specific
        to your situation — not a generic legal SEO template.
      </p>
    </div>
  </section>

  <!-- ── 5. FAQ (light) ──────────────────────────────────────── -->
  <section class="sp-content section-light">
    <div class="container sp-content-inner reveal">
      <h2 class="sp-h2">Frequently Asked Questions</h2>

      <dl class="page-faq-list">

        <div class="page-faq-item">
          <dt>
            <button class="page-faq-trigger" aria-expanded="false" aria-controls="pfaq-0" id="pfaq-btn-0">
              <span class="page-faq-question">Why do law firms need SEO?</span>
              <span class="page-faq-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <line x1="12" y1="5" x2="12" y2="19" class="pfaq-icon-v"/>
                  <line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
              </span>
            </button>
          </dt>
          <dd id="pfaq-0" class="page-faq-answer" role="region" aria-labelledby="pfaq-btn-0" hidden>
            <div class="page-faq-answer-inner">
              <p>Most people searching for legal advice start with Google. Queries like "family solicitor Manchester", "employment law advice Stockport", or "conveyancing solicitor near me" are high-intent searches from people who need a lawyer right now. Ranking for these terms generates a consistent flow of qualified client enquiries without the cost of paid advertising.</p>
            </div>
          </dd>
        </div>

        <div class="page-faq-item">
          <dt>
            <button class="page-faq-trigger" aria-expanded="false" aria-controls="pfaq-1" id="pfaq-btn-1">
              <span class="page-faq-question">What SEO tactics work best for law firms?</span>
              <span class="page-faq-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <line x1="12" y1="5" x2="12" y2="19" class="pfaq-icon-v"/>
                  <line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
              </span>
            </button>
          </dt>
          <dd id="pfaq-1" class="page-faq-answer" role="region" aria-labelledby="pfaq-btn-1" hidden>
            <div class="page-faq-answer-inner">
              <p>The most effective tactics are: dedicated practice area pages optimised for each legal service, local SEO for location-based queries, Google Business Profile optimisation, high-quality content that answers the questions potential clients are searching for, and link building from legal directories and authoritative sources. E-E-A-T signals matter particularly for legal content.</p>
            </div>
          </dd>
        </div>

        <div class="page-faq-item">
          <dt>
            <button class="page-faq-trigger" aria-expanded="false" aria-controls="pfaq-2" id="pfaq-btn-2">
              <span class="page-faq-question">Is SEO better than paid ads for law firms?</span>
              <span class="page-faq-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <line x1="12" y1="5" x2="12" y2="19" class="pfaq-icon-v"/>
                  <line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
              </span>
            </button>
          </dt>
          <dd id="pfaq-2" class="page-faq-answer" role="region" aria-labelledby="pfaq-btn-2" hidden>
            <div class="page-faq-answer-inner">
              <p>Legal PPC keywords are among the most expensive in any industry — clicks for "personal injury solicitor" or "divorce lawyer" can cost £20–£50 each. SEO requires more upfront investment in time and content but produces traffic that doesn't stop when you turn off the budget. Most law firms benefit from both, but SEO builds a durable asset that pays off over years.</p>
            </div>
          </dd>
        </div>

        <div class="page-faq-item">
          <dt>
            <button class="page-faq-trigger" aria-expanded="false" aria-controls="pfaq-3" id="pfaq-btn-3">
              <span class="page-faq-question">How do you handle YMYL content for legal sites?</span>
              <span class="page-faq-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <line x1="12" y1="5" x2="12" y2="19" class="pfaq-icon-v"/>
                  <line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
              </span>
            </button>
          </dt>
          <dd id="pfaq-3" class="page-faq-answer" role="region" aria-labelledby="pfaq-btn-3" hidden>
            <div class="page-faq-answer-inner">
              <p>Legal content falls into Google's YMYL category, meaning it's held to a higher standard for accuracy, expertise, and trustworthiness. I ensure all content attributes expertise clearly, includes appropriate disclaimers, and is structured to demonstrate E-E-A-T signals. Author credentials and firm background are incorporated into the content strategy.</p>
            </div>
          </dd>
        </div>

      </dl>
    </div>
  </section>

  <!-- ── 6. Contact CTA ───────────────────────────────────────── -->
  <ContactForm />

</ServicePage>

<style>
  .section-dark  { background-color: var(--ink);  color: var(--chalk); }
  .section-light { background-color: var(--chalk); color: var(--ink); }
  .container { max-width: 860px; margin-inline: auto; padding-inline: clamp(1.25rem, 5vw, 2rem); }
  .sp-hero { padding: 5rem 0 4rem; }
  .sp-hero-inner { display: flex; flex-direction: column; gap: 1.5rem; }
  .eyebrow { font-family: 'DM Sans', sans-serif; font-size: 0.8125rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); margin: 0; }
  .sp-h1 { font-family: 'Syne', sans-serif; font-size: clamp(2rem, 5vw, 3rem); font-weight: 700; line-height: 1.1; letter-spacing: -0.03em; color: var(--chalk); margin: 0; }
  .sp-intro { font-size: 1.125rem; line-height: 1.7; color: rgba(248, 247, 242, 0.75); max-width: 640px; }
  .btn-primary { display: inline-block; background-color: var(--accent); color: #fff; font-family: 'DM Sans', sans-serif; font-size: 0.9375rem; font-weight: 500; padding: 0.8rem 1.75rem; border-radius: 4px; transition: background-color 0.2s ease; align-self: flex-start; }
  .btn-primary:hover { background-color: var(--accent-dk); }
  .sp-content { padding: 4rem 0; }
  .sp-content-inner { display: flex; flex-direction: column; gap: 1.5rem; }
  .sp-h2 { font-family: 'Syne', sans-serif; font-size: clamp(1.5rem, 3.5vw, 2rem); font-weight: 600; letter-spacing: -0.025em; color: var(--ink); margin: 0; }
  .sp-h2.chalk { color: var(--chalk); }
  .sp-h3 { font-family: 'Syne', sans-serif; font-size: 1.125rem; font-weight: 600; color: var(--ink); margin: 0.5rem 0 0; }
  .sp-content p, .sp-content-inner p { font-size: 1.0625rem; line-height: 1.75; color: rgba(10, 10, 15, 0.8); }
  .sp-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.75rem; }
  .sp-list li { font-size: 1rem; line-height: 1.65; padding-left: 1.25rem; position: relative; color: rgba(10, 10, 15, 0.8); }
  .sp-list li::before { content: '→'; position: absolute; left: 0; color: var(--accent); font-size: 0.875rem; }
  .sp-why { padding: 4rem 0; }
  .sp-why-inner { display: flex; flex-direction: column; gap: 1.5rem; }
  .chalk { color: var(--chalk); }
  .chalk-muted { font-size: 1.0625rem; line-height: 1.75; color: rgba(248, 247, 242, 0.75); }
  .page-faq-list { margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0; }
  .page-faq-item { border-bottom: 1px solid var(--border-light); }
  .page-faq-item:first-child { border-top: 1px solid var(--border-light); }
  .page-faq-trigger { width: 100%; background: none; border: none; padding: 1.375rem 0; display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; cursor: pointer; text-align: left; }
  .page-faq-question { font-family: 'Syne', sans-serif; font-weight: 600; font-size: clamp(0.9375rem, 1.2vw, 1.0625rem); color: var(--ink); line-height: 1.4; letter-spacing: -0.01em; }
  .page-faq-icon { flex-shrink: 0; width: 32px; height: 32px; border-radius: 50%; border: 1px solid var(--border-light); display: flex; align-items: center; justify-content: center; color: var(--accent-dk); transition: background-color 0.2s ease, border-color 0.2s ease; }
  .page-faq-trigger:hover .page-faq-icon { background-color: rgba(10, 10, 15, 0.04); border-color: rgba(10, 10, 15, 0.2); }
  .pfaq-icon-v { transition: transform 0.25s ease, opacity 0.25s ease; transform-origin: center; }
  .page-faq-trigger[aria-expanded="true"] .pfaq-icon-v { transform: rotate(90deg); opacity: 0; }
  .page-faq-answer-inner { padding-bottom: 1.375rem; }
  .page-faq-answer-inner p { font-size: clamp(0.9375rem, 1.2vw, 1.0625rem); color: rgba(10, 10, 15, 0.7); line-height: 1.75; max-width: 65ch; }
  .reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.55s ease, transform 0.55s ease; }
  .reveal.visible { opacity: 1; transform: none; }
</style>

<script>
  const revealEls = document.querySelectorAll('.reveal');
  const io = new IntersectionObserver(
    (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); } }),
    { threshold: 0.12 }
  );
  revealEls.forEach(el => io.observe(el));

  const pageFaqTriggers = document.querySelectorAll<HTMLButtonElement>('.page-faq-trigger');
  pageFaqTriggers.forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const expanded = trigger.getAttribute('aria-expanded') === 'true';
      const answerId = trigger.getAttribute('aria-controls')!;
      const answer = document.getElementById(answerId)!;
      pageFaqTriggers.forEach((t) => {
        if (t !== trigger) {
          t.setAttribute('aria-expanded', 'false');
          document.getElementById(t.getAttribute('aria-controls')!)!.hidden = true;
        }
      });
      trigger.setAttribute('aria-expanded', expanded ? 'false' : 'true');
      answer.hidden = expanded;
    });
  });
</script>
