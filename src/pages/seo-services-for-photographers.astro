---
import ServicePage from '../layouts/ServicePage.astro';
import ContactForm from '../components/ContactForm.astro';
---

<script type="application/ld+json" is:inline>{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How does SEO help photographers get more bookings?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Photography is a high-intent local search category. Queries like 'wedding photographer Manchester', 'newborn photographer Stockport', or 'commercial photographer near me' come from people who have already decided they need a photographer. Ranking for these searches puts you in front of clients at exactly the right moment — and unlike social media, SEO traffic doesn't require constant content creation to maintain."
      }
    },
    {
      "@type": "Question",
      "name": "What are the most important SEO factors for photographers?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For photographers, the key SEO factors are: local SEO (Google Business Profile and local citations for geographic visibility), dedicated pages for each photography specialism (wedding, commercial, portrait, etc.), fast-loading image-optimised pages, and structured data that helps Google understand your location and services. Image alt text and file naming also matter since photography is a visual-heavy field."
      }
    },
    {
      "@type": "Question",
      "name": "Do I need an SEO-optimised portfolio or just a Google Business Profile?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Both. Your Google Business Profile is the fastest route to Map Pack visibility for local searches — it's essential. Your website portfolio needs to be optimised too: it should load fast (image-heavy sites are often slow), have service-specific pages targeting the right keywords, and be easy for both Google and potential clients to navigate. The two work together — GBP drives local discovery, your website closes the booking."
      }
    },
    {
      "@type": "Question",
      "name": "Can photographers rank on Google against the big photography directories?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes — particularly for local and specialism-specific searches. Directories like Bark or Checkatrade compete for generic searches, but a photographer with a well-optimised site and Google Business Profile can outrank them for 'wedding photographer Manchester' or 'newborn photographer Stockport' because those queries reward local relevance and specific expertise. Local SEO is the great equaliser."
      }
    }
  ]
}</script>

<ServicePage
  title="SEO for Photographers Manchester | Photography SEO Consultant | MM SEO"
  description="Freelance SEO for photographers in Manchester and across the UK. Rank for wedding, portrait and commercial photography searches. Image-optimised, fast-loading."
  canonical="https://www.mmseo.co.uk/seo-services-for-photographers/"
  breadcrumb="SEO for Photographers"
>

  <section class="sp-hero section-dark">
    <div class="container sp-hero-inner reveal">
      <p class="eyebrow">Photography SEO | Manchester, Stockport &amp; UK</p>
      <h1 class="sp-h1">SEO for Photographers in Manchester: Get Booked by Clients Who Are Searching Now</h1>
      <p class="sp-intro">
        Wedding couples, new parents, and businesses searching for a photographer in Manchester
        start with Google. I help photographers rank for the local and specialism-specific
        searches that turn into bookings — including "seo for photographers in Manchester"
        and photography searches across Greater Manchester and beyond.
      </p>
      <a href="/#contact" class="btn-primary">Book a Free Consultation</a>
    </div>
  </section>

  <section class="sp-content section-light">
    <div class="container sp-content-inner reveal">
      <h2 class="sp-h2">SEO Services for Photographers</h2>
      <p>
        Photography SEO sits at the intersection of local search and niche specialism.
        A well-optimised photographer website ranks well for the geographic searches
        ("wedding photographer Manchester") and specialism searches ("newborn photographer
        Stockport", "commercial product photographer UK") that bring in the right clients.
      </p>
      <p>
        I work with wedding photographers, portrait photographers, commercial photographers,
        event photographers, and photography studios to build the organic visibility that
        generates a consistent pipeline of enquiries.
      </p>

      <h3 class="sp-h3">What I cover</h3>
      <ul class="sp-list">
        <li><strong>Google Business Profile</strong>: Map Pack visibility for local photography searches — the most important single asset for a local photographer</li>
        <li><strong>Service-specific pages</strong>: dedicated, well-optimised pages for each photography specialism (wedding, portrait, commercial, newborn, event) targeting the specific search terms for each</li>
        <li><strong>Image SEO</strong>: alt text, file naming, structured data, and image compression — photography sites are image-heavy and require specific technical SEO attention</li>
        <li><strong>Site speed optimisation</strong>: portfolio sites are notorious for being slow; I identify and fix the performance issues that cause Google to rank you lower</li>
        <li><strong>Local SEO</strong>: location pages, citations, and geo-targeted content for the areas you serve</li>
        <li><strong>Structured data</strong>: LocalBusiness and service schema to improve how Google understands and displays your site</li>
        <li><strong>Review strategy</strong>: consistent five-star reviews on Google improve both Map Pack position and click-through rate from search results</li>
      </ul>
    </div>
  </section>

  <section class="sp-why section-dark">
    <div class="container sp-why-inner reveal">
      <h2 class="sp-h2 chalk">Why Photography SEO Requires Technical Attention</h2>
      <p class="chalk-muted">
        Portfolio sites are among the most technically challenging sites to optimise for
        SEO. They're typically image-heavy, slow to load, and built on website builders
        that don't generate clean HTML. Core Web Vitals failures are extremely common on
        photographer websites — and Google is explicit that page speed and user experience
        are ranking factors.
      </p>
      <p class="chalk-muted">
        The other challenge is that many photographers rely on social media — Instagram
        in particular — for visibility. Instagram is excellent for inspiration and
        engagement, but it doesn't capture clients who are searching with intent. Someone
        searching "wedding photographer Manchester" has already decided they want to hire
        a photographer. SEO captures that intent; social media doesn't.
      </p>
    </div>
  </section>

  <section class="sp-content section-light">
    <div class="container sp-content-inner reveal">
      <h2 class="sp-h2">Photography SEO in Manchester and Stockport</h2>
      <p>
        Greater Manchester has a thriving photography market. Wedding photographers,
        portrait studios, commercial photographers, and event photographers across
        Manchester, Stockport, Cheshire, and the wider region compete for clients who
        are increasingly finding their photographer through search.
      </p>
      <p>
        I work with photographers at all stages — from sole traders just starting to
        invest in their online presence to established studios looking to reduce their
        reliance on referrals. The strategy is always built around your specific
        specialisms, your location, and the clients you most want to attract.
      </p>
    </div>
  </section>

  <section class="sp-content section-light">
    <div class="container sp-content-inner reveal">
      <h2 class="sp-h2">Frequently Asked Questions</h2>
      <dl class="page-faq-list">
        <div class="page-faq-item">
          <dt><button class="page-faq-trigger" aria-expanded="false" aria-controls="pfaq-0" id="pfaq-btn-0"><span class="page-faq-question">How does SEO help photographers get more bookings?</span><span class="page-faq-icon" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19" class="pfaq-icon-v"/><line x1="5" y1="12" x2="19" y2="12"/></svg></span></button></dt>
          <dd id="pfaq-0" class="page-faq-answer" role="region" aria-labelledby="pfaq-btn-0" hidden><div class="page-faq-answer-inner"><p>Photography is a high-intent local search category. Queries like "wedding photographer Manchester", "newborn photographer Stockport", or "commercial photographer near me" come from people who have already decided they need a photographer. Ranking for these searches puts you in front of clients at exactly the right moment — and unlike social media, SEO traffic doesn't require constant content creation to maintain.</p></div></dd>
        </div>
        <div class="page-faq-item">
          <dt><button class="page-faq-trigger" aria-expanded="false" aria-controls="pfaq-1" id="pfaq-btn-1"><span class="page-faq-question">What are the most important SEO factors for photographers?</span><span class="page-faq-icon" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19" class="pfaq-icon-v"/><line x1="5" y1="12" x2="19" y2="12"/></svg></span></button></dt>
          <dd id="pfaq-1" class="page-faq-answer" role="region" aria-labelledby="pfaq-btn-1" hidden><div class="page-faq-answer-inner"><p>For photographers, the key SEO factors are: local SEO (Google Business Profile and local citations for geographic visibility), dedicated pages for each photography specialism, fast-loading image-optimised pages, and structured data that helps Google understand your location and services. Image alt text and file naming also matter since photography is a visual-heavy field.</p></div></dd>
        </div>
        <div class="page-faq-item">
          <dt><button class="page-faq-trigger" aria-expanded="false" aria-controls="pfaq-2" id="pfaq-btn-2"><span class="page-faq-question">Do I need an SEO-optimised portfolio or just a Google Business Profile?</span><span class="page-faq-icon" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19" class="pfaq-icon-v"/><line x1="5" y1="12" x2="19" y2="12"/></svg></span></button></dt>
          <dd id="pfaq-2" class="page-faq-answer" role="region" aria-labelledby="pfaq-btn-2" hidden><div class="page-faq-answer-inner"><p>Both. Your Google Business Profile is the fastest route to Map Pack visibility for local searches — it's essential. Your website portfolio needs to be optimised too: fast-loading, with service-specific pages targeting the right keywords, easy for both Google and potential clients to navigate. GBP drives local discovery; your website closes the booking.</p></div></dd>
        </div>
        <div class="page-faq-item">
          <dt><button class="page-faq-trigger" aria-expanded="false" aria-controls="pfaq-3" id="pfaq-btn-3"><span class="page-faq-question">Can photographers rank against the big photography directories?</span><span class="page-faq-icon" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19" class="pfaq-icon-v"/><line x1="5" y1="12" x2="19" y2="12"/></svg></span></button></dt>
          <dd id="pfaq-3" class="page-faq-answer" role="region" aria-labelledby="pfaq-btn-3" hidden><div class="page-faq-answer-inner"><p>Yes — particularly for local and specialism-specific searches. A photographer with a well-optimised site and Google Business Profile can outrank directories for "wedding photographer Manchester" or "newborn photographer Stockport" because those queries reward local relevance and specific expertise. Local SEO is the great equaliser.</p></div></dd>
        </div>
      </dl>
    </div>
  </section>

  <ContactForm />

</ServicePage>

<style>
  .section-dark  { background-color: var(--ink);  color: var(--chalk); }
  .section-light { background-color: var(--chalk); color: var(--ink); }
  .container { max-width: 860px; margin-inline: auto; padding-inline: clamp(1.25rem, 5vw, 2rem); }
  .sp-hero { padding: 5rem 0 4rem; }
  .sp-hero-inner { display: flex; flex-direction: column; gap: 1.5rem; }
  .eyebrow { font-family: 'DM Sans', sans-serif; font-size: 0.8125rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); margin: 0; }
  .sp-h1 { font-family: 'Syne', sans-serif; font-size: clamp(2rem, 5vw, 3rem); font-weight: 700; line-height: 1.1; letter-spacing: -0.03em; color: var(--chalk); margin: 0; }
  .sp-intro { font-size: 1.125rem; line-height: 1.7; color: rgba(248, 247, 242, 0.75); max-width: 640px; }
  .btn-primary { display: inline-block; background-color: var(--accent); color: #fff; font-family: 'DM Sans', sans-serif; font-size: 0.9375rem; font-weight: 500; padding: 0.8rem 1.75rem; border-radius: 4px; transition: background-color 0.2s ease; align-self: flex-start; }
  .btn-primary:hover { background-color: var(--accent-dk); }
  .sp-content { padding: 4rem 0; }
  .sp-content-inner { display: flex; flex-direction: column; gap: 1.5rem; }
  .sp-h2 { font-family: 'Syne', sans-serif; font-size: clamp(1.5rem, 3.5vw, 2rem); font-weight: 600; letter-spacing: -0.025em; color: var(--ink); margin: 0; }
  .sp-h2.chalk { color: var(--chalk); }
  .sp-h3 { font-family: 'Syne', sans-serif; font-size: 1.125rem; font-weight: 600; color: var(--ink); margin: 0.5rem 0 0; }
  .sp-content p, .sp-content-inner p { font-size: 1.0625rem; line-height: 1.75; color: rgba(10, 10, 15, 0.8); }
  .sp-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.75rem; }
  .sp-list li { font-size: 1rem; line-height: 1.65; padding-left: 1.25rem; position: relative; color: rgba(10, 10, 15, 0.8); }
  .sp-list li::before { content: '→'; position: absolute; left: 0; color: var(--accent); font-size: 0.875rem; }
  .sp-why { padding: 4rem 0; }
  .sp-why-inner { display: flex; flex-direction: column; gap: 1.5rem; }
  .chalk { color: var(--chalk); }
  .chalk-muted { font-size: 1.0625rem; line-height: 1.75; color: rgba(248, 247, 242, 0.75); }
  .page-faq-list { margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0; }
  .page-faq-item { border-bottom: 1px solid var(--border-light); }
  .page-faq-item:first-child { border-top: 1px solid var(--border-light); }
  .page-faq-trigger { width: 100%; background: none; border: none; padding: 1.375rem 0; display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; cursor: pointer; text-align: left; }
  .page-faq-question { font-family: 'Syne', sans-serif; font-weight: 600; font-size: clamp(0.9375rem, 1.2vw, 1.0625rem); color: var(--ink); line-height: 1.4; letter-spacing: -0.01em; }
  .page-faq-icon { flex-shrink: 0; width: 32px; height: 32px; border-radius: 50%; border: 1px solid var(--border-light); display: flex; align-items: center; justify-content: center; color: var(--accent-dk); transition: background-color 0.2s ease, border-color 0.2s ease; }
  .page-faq-trigger:hover .page-faq-icon { background-color: rgba(10, 10, 15, 0.04); border-color: rgba(10, 10, 15, 0.2); }
  .pfaq-icon-v { transition: transform 0.25s ease, opacity 0.25s ease; transform-origin: center; }
  .page-faq-trigger[aria-expanded="true"] .pfaq-icon-v { transform: rotate(90deg); opacity: 0; }
  .page-faq-answer-inner { padding-bottom: 1.375rem; }
  .page-faq-answer-inner p { font-size: clamp(0.9375rem, 1.2vw, 1.0625rem); color: rgba(10, 10, 15, 0.7); line-height: 1.75; max-width: 65ch; }
  .reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.55s ease, transform 0.55s ease; }
  .reveal.visible { opacity: 1; transform: none; }
</style>

<script>
  const revealEls = document.querySelectorAll('.reveal');
  const io = new IntersectionObserver(
    (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); } }),
    { threshold: 0.12 }
  );
  revealEls.forEach(el => io.observe(el));
  const pageFaqTriggers = document.querySelectorAll<HTMLButtonElement>('.page-faq-trigger');
  pageFaqTriggers.forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const expanded = trigger.getAttribute('aria-expanded') === 'true';
      const answerId = trigger.getAttribute('aria-controls')!;
      const answer = document.getElementById(answerId)!;
      pageFaqTriggers.forEach((t) => { if (t !== trigger) { t.setAttribute('aria-expanded', 'false'); document.getElementById(t.getAttribute('aria-controls')!)!.hidden = true; } });
      trigger.setAttribute('aria-expanded', expanded ? 'false' : 'true');
      answer.hidden = expanded;
    });
  });
</script>
