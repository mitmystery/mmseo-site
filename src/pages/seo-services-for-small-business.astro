---
import ServicePage from '../layouts/ServicePage.astro';
import ContactForm from '../components/ContactForm.astro';
---

<script type="application/ld+json" is:inline>{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Can small businesses afford SEO?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes — and for most small businesses, SEO is the most cost-effective marketing channel available. Unlike paid advertising, SEO builds an asset that continues to generate traffic without an ongoing budget. A focused, well-executed local SEO strategy for a small business typically costs significantly less than a comparable Google Ads campaign, and the results compound over time."
      }
    },
    {
      "@type": "Question",
      "name": "What SEO should a small business prioritise first?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For most small businesses, the priority order is: (1) fix any technical issues stopping Google from indexing the site properly, (2) optimise your Google Business Profile for local visibility, (3) ensure your key service/product pages are optimised for the right keywords, (4) build local citations and acquire early backlinks. This foundation typically delivers the fastest results for the lowest investment."
      }
    },
    {
      "@type": "Question",
      "name": "How is working with a freelance SEO consultant different from an agency?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "With a freelance consultant, you work directly with the person doing the work. There are no junior account managers, no inflated agency overheads, and no risk of being deprioritised when a larger client comes along. For small businesses, a specialist freelancer typically delivers better results for less money than a mid-tier agency — and you always know who's responsible for what."
      }
    },
    {
      "@type": "Question",
      "name": "Do you offer one-off SEO projects or only ongoing retainers?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Both. A standalone SEO audit is a great entry point — you receive a prioritised action plan you can act on immediately, whether with me or in-house. Ongoing retainers are available for small businesses that want continuous execution, reporting, and strategy refinement. There are no lock-in contracts."
      }
    }
  ]
}</script>

<ServicePage
  title="SEO for Small Businesses | Freelance SEO Consultant | MM SEO"
  description="Affordable SEO for small businesses. Freelance consultant in Stockport — no agency fees, no contracts, no lock-in. Get found locally. Manchester & UK."
  canonical="https://www.mmseo.co.uk/seo-services-for-small-business/"
  breadcrumb="SEO for Small Business"
>

  <section class="sp-hero section-dark">
    <div class="container sp-hero-inner reveal">
      <p class="eyebrow">Small Business SEO | Manchester, Stockport &amp; UK</p>
      <h1 class="sp-h1">SEO for Small Businesses: Compete on a Budget That Makes Sense</h1>
      <p class="sp-intro">
        Small businesses don't need a big agency or a big budget to win at SEO. They
        need the right priorities, executed well. I help small businesses build the
        search visibility that generates enquiries — without the overhead of an agency.
      </p>
      <a href="/#contact" class="btn-primary">Book a Free Consultation</a>
    </div>
  </section>

  <section class="sp-content section-light">
    <div class="container sp-content-inner reveal">
      <h2 class="sp-h2">Small Business SEO Services</h2>
      <p>
        Most small businesses face the same SEO situation: limited time, limited budget,
        and a market where larger competitors have more resources. The answer isn't to
        try to compete on every front — it's to identify the specific searches where
        a well-optimised small business can win and focus there.
      </p>
      <p>
        For most small businesses, that means local SEO. When you rank well for searches
        in your geographic area, you're competing against local businesses — not national
        brands with hundred-thousand-pound marketing budgets. That's a winnable game.
      </p>

      <h3 class="sp-h3">What I cover</h3>
      <ul class="sp-list">
        <li><strong>Technical SEO audit</strong>: identifying and fixing the issues that prevent Google from properly seeing and indexing your site</li>
        <li><strong>Google Business Profile</strong>: setting up and optimising your GBP for maximum local visibility</li>
        <li><strong>On-page optimisation</strong>: ensuring your pages are optimised for the right keywords with the right signals</li>
        <li><strong>Local SEO</strong>: citations, local link building, and geo-targeted content to rank for searches in your area</li>
        <li><strong>Keyword research</strong>: finding the terms your customers actually use and mapping them to your pages</li>
        <li><strong>Content strategy</strong>: practical advice on what content to create and why, without generating content for its own sake</li>
        <li><strong>Competitor analysis</strong>: understanding what competitors are doing to rank and identifying where you can outperform them</li>
        <li><strong>Monthly reporting</strong>: clear, jargon-free reporting on rankings, traffic, and commercial outcomes</li>
      </ul>
    </div>
  </section>

  <section class="sp-why section-dark">
    <div class="container sp-why-inner reveal">
      <h2 class="sp-h2 chalk">Why Small Businesses Benefit Most from Freelance SEO</h2>
      <p class="chalk-muted">
        When you hire a mid-tier agency, a significant portion of your budget goes on
        account management, project management, and overheads — not on doing the work.
        A small business with a £500–£1,000/month SEO budget is not going to be a
        priority client for most agencies. You'll get a junior team member, a templated
        strategy, and sporadic attention.
      </p>
      <p class="chalk-muted">
        As a freelance consultant, every pound you spend goes on actual SEO work. You
        deal directly with me — the person who knows your site, your market, and your
        goals. There are no contracts, no lock-in periods, and no minimum terms.
        If the work stops producing results, you can stop. Most of my small business
        clients don't — because they see the results.
      </p>
    </div>
  </section>

  <section class="sp-content section-light">
    <div class="container sp-content-inner reveal">
      <h2 class="sp-h2">Small Business SEO in Manchester and Stockport</h2>
      <p>
        I'm based in Stockport and work with small businesses across Greater Manchester
        and the UK. Whether you're a tradesperson in Stockport, a professional services
        firm in Manchester, a retailer in Cheshire, or a service business anywhere in
        the UK — the principles of small business SEO are the same, and I apply them
        to your specific situation.
      </p>
      <p>
        Most of my small business clients come to me with the same brief: "I know I
        need to do something about SEO but I don't know where to start or what to
        prioritise." That's exactly what I help with. We start with a clear picture
        of where you are, identify the highest-value opportunities, and build from there.
      </p>
    </div>
  </section>

  <section class="sp-content section-light">
    <div class="container sp-content-inner reveal">
      <h2 class="sp-h2">Frequently Asked Questions</h2>
      <dl class="page-faq-list">
        <div class="page-faq-item">
          <dt><button class="page-faq-trigger" aria-expanded="false" aria-controls="pfaq-0" id="pfaq-btn-0"><span class="page-faq-question">Can small businesses afford SEO?</span><span class="page-faq-icon" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19" class="pfaq-icon-v"/><line x1="5" y1="12" x2="19" y2="12"/></svg></span></button></dt>
          <dd id="pfaq-0" class="page-faq-answer" role="region" aria-labelledby="pfaq-btn-0" hidden><div class="page-faq-answer-inner"><p>Yes — and for most small businesses, SEO is the most cost-effective marketing channel available. Unlike paid advertising, SEO builds an asset that continues to generate traffic without an ongoing budget. A focused, well-executed local SEO strategy typically costs significantly less than a comparable Google Ads campaign, and the results compound over time.</p></div></dd>
        </div>
        <div class="page-faq-item">
          <dt><button class="page-faq-trigger" aria-expanded="false" aria-controls="pfaq-1" id="pfaq-btn-1"><span class="page-faq-question">What SEO should a small business prioritise first?</span><span class="page-faq-icon" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19" class="pfaq-icon-v"/><line x1="5" y1="12" x2="19" y2="12"/></svg></span></button></dt>
          <dd id="pfaq-1" class="page-faq-answer" role="region" aria-labelledby="pfaq-btn-1" hidden><div class="page-faq-answer-inner"><p>For most small businesses, the priority order is: (1) fix any technical issues stopping Google from indexing the site properly, (2) optimise your Google Business Profile for local visibility, (3) ensure your key service/product pages are optimised for the right keywords, (4) build local citations and acquire early backlinks. This foundation typically delivers the fastest results for the lowest investment.</p></div></dd>
        </div>
        <div class="page-faq-item">
          <dt><button class="page-faq-trigger" aria-expanded="false" aria-controls="pfaq-2" id="pfaq-btn-2"><span class="page-faq-question">How is working with a freelance consultant different from an agency?</span><span class="page-faq-icon" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19" class="pfaq-icon-v"/><line x1="5" y1="12" x2="19" y2="12"/></svg></span></button></dt>
          <dd id="pfaq-2" class="page-faq-answer" role="region" aria-labelledby="pfaq-btn-2" hidden><div class="page-faq-answer-inner"><p>With a freelance consultant, you work directly with the person doing the work. No junior account managers, no inflated agency overheads, and no risk of being deprioritised when a larger client comes along. A specialist freelancer typically delivers better results for less money than a mid-tier agency — and you always know who's responsible for what.</p></div></dd>
        </div>
        <div class="page-faq-item">
          <dt><button class="page-faq-trigger" aria-expanded="false" aria-controls="pfaq-3" id="pfaq-btn-3"><span class="page-faq-question">Do you offer one-off projects or only ongoing retainers?</span><span class="page-faq-icon" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19" class="pfaq-icon-v"/><line x1="5" y1="12" x2="19" y2="12"/></svg></span></button></dt>
          <dd id="pfaq-3" class="page-faq-answer" role="region" aria-labelledby="pfaq-btn-3" hidden><div class="page-faq-answer-inner"><p>Both. A standalone SEO audit is a great entry point — you receive a prioritised action plan you can act on immediately, whether with me or in-house. Ongoing retainers are available for businesses that want continuous execution and reporting. There are no lock-in contracts.</p></div></dd>
        </div>
      </dl>
    </div>
  </section>

  <ContactForm />

</ServicePage>

<style>
  .section-dark  { background-color: var(--ink);  color: var(--chalk); }
  .section-light { background-color: var(--chalk); color: var(--ink); }
  .container { max-width: 860px; margin-inline: auto; padding-inline: clamp(1.25rem, 5vw, 2rem); }
  .sp-hero { padding: 5rem 0 4rem; }
  .sp-hero-inner { display: flex; flex-direction: column; gap: 1.5rem; }
  .eyebrow { font-family: 'DM Sans', sans-serif; font-size: 0.8125rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); margin: 0; }
  .sp-h1 { font-family: 'Syne', sans-serif; font-size: clamp(2rem, 5vw, 3rem); font-weight: 700; line-height: 1.1; letter-spacing: -0.03em; color: var(--chalk); margin: 0; }
  .sp-intro { font-size: 1.125rem; line-height: 1.7; color: rgba(248, 247, 242, 0.75); max-width: 640px; }
  .btn-primary { display: inline-block; background-color: var(--accent); color: #fff; font-family: 'DM Sans', sans-serif; font-size: 0.9375rem; font-weight: 500; padding: 0.8rem 1.75rem; border-radius: 4px; transition: background-color 0.2s ease; align-self: flex-start; }
  .btn-primary:hover { background-color: var(--accent-dk); }
  .sp-content { padding: 4rem 0; }
  .sp-content-inner { display: flex; flex-direction: column; gap: 1.5rem; }
  .sp-h2 { font-family: 'Syne', sans-serif; font-size: clamp(1.5rem, 3.5vw, 2rem); font-weight: 600; letter-spacing: -0.025em; color: var(--ink); margin: 0; }
  .sp-h2.chalk { color: var(--chalk); }
  .sp-h3 { font-family: 'Syne', sans-serif; font-size: 1.125rem; font-weight: 600; color: var(--ink); margin: 0.5rem 0 0; }
  .sp-content p, .sp-content-inner p { font-size: 1.0625rem; line-height: 1.75; color: rgba(10, 10, 15, 0.8); }
  .sp-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.75rem; }
  .sp-list li { font-size: 1rem; line-height: 1.65; padding-left: 1.25rem; position: relative; color: rgba(10, 10, 15, 0.8); }
  .sp-list li::before { content: '→'; position: absolute; left: 0; color: var(--accent); font-size: 0.875rem; }
  .sp-why { padding: 4rem 0; }
  .sp-why-inner { display: flex; flex-direction: column; gap: 1.5rem; }
  .chalk { color: var(--chalk); }
  .chalk-muted { font-size: 1.0625rem; line-height: 1.75; color: rgba(248, 247, 242, 0.75); }
  .page-faq-list { margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0; }
  .page-faq-item { border-bottom: 1px solid var(--border-light); }
  .page-faq-item:first-child { border-top: 1px solid var(--border-light); }
  .page-faq-trigger { width: 100%; background: none; border: none; padding: 1.375rem 0; display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; cursor: pointer; text-align: left; }
  .page-faq-question { font-family: 'Syne', sans-serif; font-weight: 600; font-size: clamp(0.9375rem, 1.2vw, 1.0625rem); color: var(--ink); line-height: 1.4; letter-spacing: -0.01em; }
  .page-faq-icon { flex-shrink: 0; width: 32px; height: 32px; border-radius: 50%; border: 1px solid var(--border-light); display: flex; align-items: center; justify-content: center; color: var(--accent-dk); transition: background-color 0.2s ease, border-color 0.2s ease; }
  .page-faq-trigger:hover .page-faq-icon { background-color: rgba(10, 10, 15, 0.04); border-color: rgba(10, 10, 15, 0.2); }
  .pfaq-icon-v { transition: transform 0.25s ease, opacity 0.25s ease; transform-origin: center; }
  .page-faq-trigger[aria-expanded="true"] .pfaq-icon-v { transform: rotate(90deg); opacity: 0; }
  .page-faq-answer-inner { padding-bottom: 1.375rem; }
  .page-faq-answer-inner p { font-size: clamp(0.9375rem, 1.2vw, 1.0625rem); color: rgba(10, 10, 15, 0.7); line-height: 1.75; max-width: 65ch; }
  .reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.55s ease, transform 0.55s ease; }
  .reveal.visible { opacity: 1; transform: none; }
</style>

<script>
  const revealEls = document.querySelectorAll('.reveal');
  const io = new IntersectionObserver(
    (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); } }),
    { threshold: 0.12 }
  );
  revealEls.forEach(el => io.observe(el));
  const pageFaqTriggers = document.querySelectorAll<HTMLButtonElement>('.page-faq-trigger');
  pageFaqTriggers.forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const expanded = trigger.getAttribute('aria-expanded') === 'true';
      const answerId = trigger.getAttribute('aria-controls')!;
      const answer = document.getElementById(answerId)!;
      pageFaqTriggers.forEach((t) => { if (t !== trigger) { t.setAttribute('aria-expanded', 'false'); document.getElementById(t.getAttribute('aria-controls')!)!.hidden = true; } });
      trigger.setAttribute('aria-expanded', expanded ? 'false' : 'true');
      answer.hidden = expanded;
    });
  });
</script>
