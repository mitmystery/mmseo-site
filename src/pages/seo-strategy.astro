---
import ServicePage from '../layouts/ServicePage.astro';
import ContactForm from '../components/ContactForm.astro';
---

<script type="application/ld+json" is:inline>{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How long does it take to develop an SEO strategy?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A thorough SEO strategy typically takes 2–3 weeks to develop from scratch. This includes a technical audit, competitor analysis, keyword research, content gap analysis, and the roadmap itself. For clients with urgent timelines, a lighter version can be delivered faster — but rushing strategy usually costs more time in execution."
      }
    },
    {
      "@type": "Question",
      "name": "What does an SEO strategy deliverable look like?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The output is a prioritised action plan covering technical fixes, content opportunities, and off-page work, with timelines and expected outcomes for each area. It's designed to be acted on immediately — either by me, your in-house team, or a combination of both."
      }
    },
    {
      "@type": "Question",
      "name": "Should I have an SEO strategy before doing any SEO work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Without a clear strategy, SEO activity tends to be fragmented and slow to produce results. The strategy defines what to work on first, why, and in what order. Even a light strategy document is better than starting with tactics and hoping they add up to something."
      }
    },
    {
      "@type": "Question",
      "name": "How often should an SEO strategy be reviewed?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "SEO strategies should be reviewed quarterly at minimum. The search landscape changes — competitors update their sites, Google rolls out algorithm updates, and your own business goals may shift. A good strategy is a living document that evolves as the data develops, not a one-time report."
      }
    }
  ]
}</script>

<ServicePage
  title="SEO Strategy Consultant Stockport & Manchester | MM SEO"
  description="Freelance SEO strategy consultant in Stockport. Competitor analysis, keyword research and clear prioritised roadmaps. Free consultation — Manchester & UK."
  canonical="https://www.mmseo.co.uk/seo-strategy/"
  breadcrumb="SEO Strategy"
>

  <!-- ── 1. Hero band (dark) ─────────────────────────────────── -->
  <section class="sp-hero section-dark">
    <div class="container sp-hero-inner reveal">
      <p class="eyebrow">SEO Strategy Consultant | Manchester &amp; UK</p>
      <h1 class="sp-h1">SEO Strategy: A Roadmap That Actually Goes Somewhere</h1>
      <p class="sp-intro">
        Most SEO agencies give you a list of tactics and call it a strategy. A real
        strategy starts with your business goals, maps the search landscape around
        them, and produces a prioritised plan of action that connects what you do
        in month one to where you want to be in month twelve.
      </p>
      <a href="/#contact" class="btn-primary">Book a Free Consultation</a>
    </div>
  </section>

  <!-- ── 2. Main content (light) ─────────────────────────────── -->
  <section class="sp-content section-light">
    <div class="container sp-content-inner reveal">
      <h2 class="sp-h2">What Proper SEO Strategy Looks Like</h2>

      <p>
        Strategy without execution is just planning. Execution without strategy is
        just activity. The campaigns that consistently deliver results are the ones
        where every task (every piece of content, every technical fix, every link
        built) is connected to a clear commercial objective and a realistic path
        to getting there.
      </p>
      <p>
        I build SEO strategies that are specific to your business, your market, and
        your competitors. Not a templated deliverable with your logo pasted on the
        front: a working document that shapes everything we do and evolves as the
        data tells us what's working.
      </p>

      <h3 class="sp-h3">How I build an SEO strategy</h3>
      <ul class="sp-list">
        <li><strong>Discovery</strong>: understanding your business goals, revenue model, target customers, and what success looks like in concrete terms</li>
        <li><strong>Technical audit</strong>: assessing the current health of your site and identifying any foundational issues that need resolving before other work can scale</li>
        <li><strong>Competitor analysis</strong>: mapping who you're competing against in search, what they're doing well, and where their weaknesses are</li>
        <li><strong>Keyword &amp; opportunity research</strong>: identifying the terms your customers search for, mapped to intent and prioritised by commercial value and attainability</li>
        <li><strong>Content gap analysis</strong>: finding the topics and pages you're missing that your competitors have, and that your customers need</li>
        <li><strong>Prioritised roadmap</strong>: a sequenced plan of action across technical, on-page, content, and off-page work, with short, medium, and long-term milestones</li>
        <li><strong>KPI framework</strong>: agreeing the metrics that matter (rankings, organic traffic, leads, revenue) and how we'll track progress against them</li>
      </ul>
    </div>
  </section>

  <!-- ── 3. Why it matters (dark) ────────────────────────────── -->
  <section class="sp-why section-dark">
    <div class="container sp-why-inner reveal">
      <h2 class="sp-h2 chalk">Strategy Looks Different for Different Businesses</h2>
      <p class="chalk-muted">
        A local service business in Stockport needs a very different strategy from
        a national eCommerce retailer, even if both want "more organic traffic."
        The local business should lead with GBP optimisation, local citations, and
        geo-targeted content. The eCommerce retailer needs to start with technical
        crawl coverage, category page optimisation, and product schema. Applying
        the same framework to both is how generic agencies produce generic results.
      </p>
      <p class="chalk-muted">
        Short-term strategy focuses on the fixes and optimisations that will produce
        movement in 0–3 months: technical issues, on-page improvements, and capturing
        near-ranking terms. Medium-term strategy builds content and authority. Long-term
        strategy establishes durable topical leadership in your niche, the kind of
        organic presence that becomes a genuine competitive moat.
      </p>
      <p class="chalk-muted">
        I also build strategies with honest timelines. If you're asking me what to
        expect in three months versus twelve months, I'll tell you the truth, not
        what you want to hear. That's the only way to build a client relationship
        that produces results worth talking about.
      </p>
    </div>
  </section>

  <!-- ── 4. What an SEO Strategy Actually Includes (light) ─────── -->
  <section class="sp-content section-light">
    <div class="container sp-content-inner reveal">
      <h2 class="sp-h2">What Does an SEO Strategy Actually Include?</h2>
      <p>
        The word "strategy" gets thrown around loosely in SEO. What I mean by it is a
        documented, prioritised plan — built on evidence — that connects your business
        objectives to specific SEO actions, with timelines, success metrics, and clear logic
        for every decision.
      </p>
      <p>
        A proper SEO strategy is not a list of tactics. It is a coherent plan that answers:
        where are you now, where do you need to get to, what is standing in the way, and in
        what order should we address it.
      </p>
    </div>
  </section>

  <!-- ── 5. My SEO Strategy Process (dark) ─────────────────────── -->
  <section class="sp-why section-dark">
    <div class="container sp-why-inner reveal">
      <h2 class="sp-h2 chalk">My SEO Strategy Process</h2>

      <h3 class="sp-h3 chalk">1. Discovery and Baseline Audit</h3>
      <p class="chalk-muted">
        Every strategy starts with understanding where you actually are. I conduct a
        <a href="/technical-seo/" class="sp-inline-link chalk-link">technical audit</a> of your site,
        a keyword position baseline, an analysis of your current traffic sources, and a review
        of your existing content. This gives us a factual starting point — not assumptions.
      </p>

      <h3 class="sp-h3 chalk">2. Competitor and Market Analysis</h3>
      <p class="chalk-muted">
        I map your search landscape — who is ranking for the terms you want, what they are
        doing to rank there, and where the gaps are. This tells us where the realistic
        opportunities are and what effort they require.
      </p>

      <h3 class="sp-h3 chalk">3. Keyword Research and Intent Mapping</h3>
      <p class="chalk-muted">
        I identify the full keyword universe relevant to your business and map each term to a
        stage in the customer journey — awareness, consideration, decision. This
        <a href="/keyword-research/" class="sp-inline-link chalk-link">keyword research</a>
        determines what content you need to create, what pages need to be optimised, and where
        to focus first.
      </p>

      <h3 class="sp-h3 chalk">4. Prioritised Roadmap</h3>
      <p class="chalk-muted">
        The output of strategy is a prioritised action plan. Not everything can be done at
        once, and not everything has equal impact. I prioritise by a combination of effort,
        impact, and urgency — so the most valuable work happens first and you see results as
        early as possible.
      </p>

      <h3 class="sp-h3 chalk">5. Success Metrics</h3>
      <p class="chalk-muted">
        A strategy without measurement is guesswork. I define the metrics that matter for your
        business — organic traffic, ranking positions, leads generated, revenue attributed to
        organic — and establish the tracking needed to monitor them. Reporting is built into
        the strategy from day one.
      </p>
    </div>
  </section>

  <!-- ── 6. SEO Strategy for Different Business Types (light) ───── -->
  <section class="sp-content section-light">
    <div class="container sp-content-inner reveal">
      <h2 class="sp-h2">SEO Strategy for Different Business Types</h2>
      <p>
        The right SEO strategy looks different depending on your business model:
      </p>
      <ul class="sp-list">
        <li><strong>eCommerce</strong>: priority is usually technical foundations, category page optimisation, and product content — then link building to build authority.</li>
        <li><strong>Professional services and local businesses</strong>: local SEO, Google Business Profile, and location-specific content typically deliver the fastest ROI.</li>
        <li><strong>B2B and SaaS</strong>: content-led strategies targeting informational queries at the top of the funnel, converting to commercial intent content lower down.</li>
        <li><strong>New websites</strong>: technical setup, keyword architecture, and content creation take priority before link building.</li>
      </ul>
      <p>
        I assess which model fits your business and build the strategy accordingly. As an
        <strong>SEO strategy consultant in Stockport</strong> with experience across sectors,
        I provide <strong>SEO strategy consulting in Manchester</strong> and across the UK,
        tailored to your specific business goals rather than a generic template.
      </p>
    </div>
  </section>

  <!-- ── 7. One-Off vs Ongoing (dark) ──────────────────────────── -->
  <section class="sp-why section-dark">
    <div class="container sp-why-inner reveal">
      <h2 class="sp-h2 chalk">One-Off Strategy vs Ongoing Consultancy</h2>
      <p class="chalk-muted">
        Some clients want a strategy document they can execute themselves or hand to an
        in-house team. Others want ongoing consultancy where I build and execute the strategy
        continuously. Both are available.
      </p>
      <p class="chalk-muted">
        A one-off <strong>SEO strategy</strong> engagement typically includes the full audit,
        competitor analysis, keyword research, and a 6-month prioritised roadmap. An ongoing
        retainer includes all of that plus monthly execution, reporting, and continuous
        refinement as the data develops.
      </p>
      <p class="chalk-muted">
        Whether you're looking for <strong>SEO consulting in Stockport</strong>, an
        <strong>SEO strategy in Manchester</strong>, or a remote UK-wide engagement — I work
        the same way: evidence first, clear priorities, honest timelines.
      </p>
    </div>
  </section>

  <!-- ── 8. Relevant result (light) ──────────────────────────── -->
  <section class="sp-result section-light">
    <div class="container sp-result-inner reveal">
      <p class="eyebrow dark-eyebrow">Proven Results</p>
      <blockquote class="sp-quote">
        <p class="sp-quote-metric">+95% organic traffic · +99.5% revenue</p>
        <p class="sp-quote-context">
          Number 1 Plates needed a strategy built from first principles: an in-depth
          technical audit, keyword strategy backed by competitor and persona research,
          and a phased execution plan. The result: core product keywords in the top
          three, 95% organic traffic growth, and revenue that nearly doubled.
        </p>
        <footer class="sp-quote-credit">— Number 1 Plates (Automotive eCommerce · UK)</footer>
      </blockquote>
    </div>
  </section>

  <!-- ── 9. Page FAQ (light) ──────────────────────────────────── -->
  <section class="sp-content section-light">
    <div class="container sp-content-inner reveal">
      <h2 class="sp-h2">Frequently Asked Questions</h2>

      <dl class="page-faq-list">

        <div class="page-faq-item">
          <dt>
            <button class="page-faq-trigger" aria-expanded="false" aria-controls="pfaq-0" id="pfaq-btn-0">
              <span class="page-faq-question">How long does it take to develop an SEO strategy?</span>
              <span class="page-faq-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <line x1="12" y1="5" x2="12" y2="19" class="pfaq-icon-v"/>
                  <line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
              </span>
            </button>
          </dt>
          <dd id="pfaq-0" class="page-faq-answer" role="region" aria-labelledby="pfaq-btn-0" hidden>
            <div class="page-faq-answer-inner">
              <p>A thorough SEO strategy typically takes 2–3 weeks to develop from scratch. This includes a technical audit, competitor analysis, keyword research, content gap analysis, and the roadmap itself. For clients with urgent timelines, a lighter version can be delivered faster — but rushing strategy usually costs more time in execution.</p>
            </div>
          </dd>
        </div>

        <div class="page-faq-item">
          <dt>
            <button class="page-faq-trigger" aria-expanded="false" aria-controls="pfaq-1" id="pfaq-btn-1">
              <span class="page-faq-question">What does an SEO strategy deliverable look like?</span>
              <span class="page-faq-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <line x1="12" y1="5" x2="12" y2="19" class="pfaq-icon-v"/>
                  <line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
              </span>
            </button>
          </dt>
          <dd id="pfaq-1" class="page-faq-answer" role="region" aria-labelledby="pfaq-btn-1" hidden>
            <div class="page-faq-answer-inner">
              <p>The output is a prioritised action plan covering technical fixes, content opportunities, and off-page work, with timelines and expected outcomes for each area. It's designed to be acted on immediately — either by me, your in-house team, or a combination of both.</p>
            </div>
          </dd>
        </div>

        <div class="page-faq-item">
          <dt>
            <button class="page-faq-trigger" aria-expanded="false" aria-controls="pfaq-2" id="pfaq-btn-2">
              <span class="page-faq-question">Should I have an SEO strategy before doing any SEO work?</span>
              <span class="page-faq-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <line x1="12" y1="5" x2="12" y2="19" class="pfaq-icon-v"/>
                  <line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
              </span>
            </button>
          </dt>
          <dd id="pfaq-2" class="page-faq-answer" role="region" aria-labelledby="pfaq-btn-2" hidden>
            <div class="page-faq-answer-inner">
              <p>Yes. Without a clear strategy, SEO activity tends to be fragmented and slow to produce results. The strategy defines what to work on first, why, and in what order. Even a light strategy document is better than starting with tactics and hoping they add up to something.</p>
            </div>
          </dd>
        </div>

        <div class="page-faq-item">
          <dt>
            <button class="page-faq-trigger" aria-expanded="false" aria-controls="pfaq-3" id="pfaq-btn-3">
              <span class="page-faq-question">How often should an SEO strategy be reviewed?</span>
              <span class="page-faq-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <line x1="12" y1="5" x2="12" y2="19" class="pfaq-icon-v"/>
                  <line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
              </span>
            </button>
          </dt>
          <dd id="pfaq-3" class="page-faq-answer" role="region" aria-labelledby="pfaq-btn-3" hidden>
            <div class="page-faq-answer-inner">
              <p>SEO strategies should be reviewed quarterly at minimum. The search landscape changes — competitors update their sites, Google rolls out algorithm updates, and your own business goals may shift. A good strategy is a living document that evolves as the data develops, not a one-time report.</p>
            </div>
          </dd>
        </div>

      </dl>
    </div>
  </section>

  <!-- ── 10. Contact CTA ──────────────────────────────────────── -->
  <ContactForm />

</ServicePage>

<style>
  .section-dark  { background-color: var(--ink);  color: var(--chalk); }
  .section-light { background-color: var(--chalk); color: var(--ink); }

  .container {
    max-width: 860px;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 5vw, 2rem);
  }

  .sp-hero { padding: 5rem 0 4rem; }
  .sp-hero-inner { display: flex; flex-direction: column; gap: 1.5rem; }

  .eyebrow {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0;
  }
  .dark-eyebrow { color: var(--accent); }

  .sp-h1 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--chalk);
    margin: 0;
  }

  .sp-intro {
    font-size: 1.125rem;
    line-height: 1.7;
    color: rgba(248, 247, 242, 0.75);
    max-width: 640px;
  }

  .btn-primary {
    display: inline-block;
    background-color: var(--accent);
    color: #fff;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    font-weight: 500;
    padding: 0.8rem 1.75rem;
    border-radius: 4px;
    transition: background-color 0.2s ease;
    align-self: flex-start;
  }
  .btn-primary:hover { background-color: var(--accent-dk); }

  .sp-content { padding: 4rem 0; }
  .sp-content-inner { display: flex; flex-direction: column; gap: 1.5rem; }

  .sp-h2 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin: 0;
  }
  .sp-h2.chalk { color: var(--chalk); }

  .sp-h3 {
    font-family: 'Syne', sans-serif;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--ink);
    margin: 0.5rem 0 0;
  }

  .sp-content p, .sp-content-inner p {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: rgba(10, 10, 15, 0.8);
  }

  .sp-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .sp-list li {
    font-size: 1rem;
    line-height: 1.65;
    padding-left: 1.25rem;
    position: relative;
    color: rgba(10, 10, 15, 0.8);
  }
  .sp-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-size: 0.875rem;
  }

  .sp-why { padding: 4rem 0; }
  .sp-why-inner { display: flex; flex-direction: column; gap: 1.5rem; }
  .chalk { color: var(--chalk); }
  .chalk-muted {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: rgba(248, 247, 242, 0.75);
  }

  .sp-h3.chalk { color: var(--chalk); }

  .sp-inline-link {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: rgba(255, 104, 38, 0.45);
    text-underline-offset: 2px;
    transition: color 0.2s ease;
  }
  .sp-inline-link:hover { color: var(--accent-dk); }

  .chalk-link {
    color: rgba(255, 104, 38, 0.85);
    text-decoration-color: rgba(255, 104, 38, 0.35);
  }
  .chalk-link:hover { color: var(--accent); }

  .sp-result { padding: 4rem 0; }
  .sp-result-inner { display: flex; flex-direction: column; gap: 1.5rem; }

  .sp-quote {
    margin: 0;
    padding: 2rem;
    border-left: 3px solid var(--accent);
    background-color: rgba(10, 10, 15, 0.04);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .sp-quote-metric {
    font-family: 'DM Mono', monospace;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--ink);
    margin: 0;
  }
  .sp-quote-context {
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(10, 10, 15, 0.75);
    margin: 0;
  }
  .sp-quote-credit {
    font-size: 0.875rem;
    color: var(--muted);
    font-style: normal;
  }

  /* ── Page FAQ ────────────────────────────────────────────────── */
  .page-faq-list {
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .page-faq-item { border-bottom: 1px solid var(--border-light); }
  .page-faq-item:first-child { border-top: 1px solid var(--border-light); }
  .page-faq-trigger {
    width: 100%;
    background: none;
    border: none;
    padding: 1.375rem 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    cursor: pointer;
    text-align: left;
  }
  .page-faq-question {
    font-family: 'Syne', sans-serif;
    font-weight: 600;
    font-size: clamp(0.9375rem, 1.2vw, 1.0625rem);
    color: var(--ink);
    line-height: 1.4;
    letter-spacing: -0.01em;
  }
  .page-faq-icon {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid var(--border-light);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent-dk);
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }
  .page-faq-trigger:hover .page-faq-icon {
    background-color: rgba(10, 10, 15, 0.04);
    border-color: rgba(10, 10, 15, 0.2);
  }
  .pfaq-icon-v {
    transition: transform 0.25s ease, opacity 0.25s ease;
    transform-origin: center;
  }
  .page-faq-trigger[aria-expanded="true"] .pfaq-icon-v {
    transform: rotate(90deg);
    opacity: 0;
  }
  .page-faq-answer-inner { padding-bottom: 1.375rem; }
  .page-faq-answer-inner p {
    font-size: clamp(0.9375rem, 1.2vw, 1.0625rem);
    color: rgba(10, 10, 15, 0.7);
    line-height: 1.75;
    max-width: 65ch;
  }

  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: none;
  }
</style>

<script>
  const revealEls = document.querySelectorAll('.reveal');
  const io = new IntersectionObserver(
    (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); } }),
    { threshold: 0.12 }
  );
  revealEls.forEach(el => io.observe(el));

  const pageFaqTriggers = document.querySelectorAll<HTMLButtonElement>('.page-faq-trigger');
  pageFaqTriggers.forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const expanded = trigger.getAttribute('aria-expanded') === 'true';
      const answerId = trigger.getAttribute('aria-controls')!;
      const answer = document.getElementById(answerId)!;
      pageFaqTriggers.forEach((t) => {
        if (t !== trigger) {
          t.setAttribute('aria-expanded', 'false');
          document.getElementById(t.getAttribute('aria-controls')!)!.hidden = true;
        }
      });
      trigger.setAttribute('aria-expanded', expanded ? 'false' : 'true');
      answer.hidden = expanded;
    });
  });
</script>
