---
import ServicePage from '../layouts/ServicePage.astro';
import ContactForm from '../components/ContactForm.astro';
---

<script type="application/ld+json" is:inline>{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is included in a technical SEO audit?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A technical SEO audit covers crawlability and indexation, Core Web Vitals (LCP, CLS, INP), site architecture, structured data, site speed, mobile usability, HTTPS setup, duplicate content, and internal linking. You receive a prioritised action plan explaining each issue in plain language and how to fix it."
      }
    },
    {
      "@type": "Question",
      "name": "How long does a technical SEO audit take?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For most small to medium business websites, a comprehensive technical SEO audit takes 3–5 days to complete. Larger eCommerce sites or those with complex architectures may take 7–10 days. You'll receive a full report with prioritised recommendations at the end."
      }
    },
    {
      "@type": "Question",
      "name": "Can technical SEO issues cause ranking drops?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes — many ranking drops are caused by technical issues rather than content or link-related factors. Common culprits include accidental noindex tags, redirect chains diluting link equity, canonicalisation errors, and Core Web Vitals failures. Technical SEO should be the first thing investigated when rankings unexpectedly fall."
      }
    },
    {
      "@type": "Question",
      "name": "Do I need ongoing technical SEO or is a one-off audit enough?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A one-off audit is a great starting point that surfaces the issues currently holding your site back. Ongoing technical SEO makes sense for sites that publish frequently, run major development projects, or need continuous monitoring for crawl errors, indexation problems, and Core Web Vitals regressions. I offer both."
      }
    }
  ]
}</script>

<ServicePage
  title="Technical SEO Consultant Stockport & Manchester | MM SEO"
  description="Freelance technical SEO consultant in Stockport. Crawl audits, Core Web Vitals fixes, indexation issues — 18 years experience. Free consultation, no contracts."
  canonical="https://www.mmseo.co.uk/technical-seo/"
  breadcrumb="Technical SEO"
>

  <!-- ── 1. Hero band (dark) ─────────────────────────────────── -->
  <section class="sp-hero section-dark">
    <div class="container sp-hero-inner reveal">
      <p class="eyebrow">Technical SEO Consultant | Manchester &amp; UK</p>
      <h1 class="sp-h1">Technical SEO: Fixing What's Holding Your Site Back</h1>
      <p class="sp-intro">
        If Google can't properly crawl, interpret, and index your site, no amount of great
        content or backlinks will get you to page one. I diagnose and fix the technical
        foundations that underpin every successful SEO campaign.
      </p>
      <p class="sp-intro-sub">
        I provide technical SEO consultancy to businesses across Manchester, Stockport, and
        the UK — fixing the crawlability, speed, and indexation issues that stop Google from
        properly seeing and ranking your site.
      </p>
      <a href="/#contact" class="btn-primary">Book a Free Consultation</a>
    </div>
  </section>

  <!-- ── 2. Main content (light) ─────────────────────────────── -->
  <section class="sp-content section-light">
    <div class="container sp-content-inner reveal">
      <h2 class="sp-h2">What a Technical SEO Audit Covers</h2>

      <p>
        A technical SEO audit is the starting point for every campaign I run. It gives us
        a complete picture of how search engines see your site and surfaces the issues that
        are directly costing you rankings and traffic.
      </p>
      <p>
        Using tools including Screaming Frog, Sitebulb, Google Search Console, and
        PageSpeed Insights, I conduct a systematic review across every critical dimension
        of your site's technical health.
      </p>
      <p>
        You receive a prioritised action plan, not a raw data dump. Each issue is
        explained in plain language with a clear recommendation, ranked by the impact
        it will have on your organic performance.
      </p>

      <h3 class="sp-h3">What I examine</h3>
      <ul class="sp-list">
        <li><strong>Crawlability &amp; indexation</strong>: robots.txt, XML sitemaps, noindex tags, crawl budget, canonicalsation issues</li>
        <li><strong>Core Web Vitals</strong>: LCP, CLS, INP across mobile and desktop; specific recommendations for improvement</li>
        <li><strong>Site architecture</strong>: URL structure, internal linking, depth, orphan pages, pagination</li>
        <li><strong>Structured data</strong>: Schema.org markup validation, rich result eligibility, implementation gaps</li>
        <li><strong>Site speed</strong>: render-blocking resources, image optimisation, server response times, caching</li>
        <li><strong>Mobile usability</strong>: mobile-first indexing compliance, tap target sizing, viewport configuration</li>
        <li><strong>HTTPS &amp; security</strong>: mixed content, redirect chains, HSTS, security headers</li>
        <li><strong>Duplicate content</strong>: parameter handling, faceted navigation issues, thin content pages</li>
        <li><strong>International SEO</strong> (where relevant): hreflang implementation, geo-targeting in GSC</li>
        <li><strong>Log file analysis</strong> (advanced audits): how Googlebot actually crawls your site vs. what it should</li>
      </ul>
    </div>
  </section>

  <!-- ── 3. Why it matters (dark) ────────────────────────────── -->
  <section class="sp-why section-dark">
    <div class="container sp-why-inner reveal">
      <h2 class="sp-h2 chalk">Why Technical SEO is the Foundation</h2>
      <p class="chalk-muted">
        Technical SEO is the infrastructure that everything else sits on. You can produce
        the best content in your industry and earn high-quality backlinks, but if your
        site has fundamental crawlability or speed issues, Google will struggle to
        evaluate and reward that work.
      </p>
      <p class="chalk-muted">
        The issues I most commonly find, the ones that cause the most damage, are the ones
        that are invisible to the naked eye. Canonical tags pointing the wrong way,
        JavaScript-rendered content that crawlers can't see, slow server response times
        on category pages, internal link structures that bury your most important pages.
        These aren't glamorous fixes, but they unlock everything else.
      </p>
      <p class="chalk-muted">
        After a technical audit and implementation, clients typically see improvements
        in crawl coverage, faster indexing of new content, and meaningful lifts in
        Core Web Vitals scores, all of which feed directly into rankings.
      </p>
    </div>
  </section>

  <!-- ── 4. Relevant result (light) ──────────────────────────── -->
  <section class="sp-result section-light">
    <div class="container sp-result-inner reveal">
      <p class="eyebrow dark-eyebrow">Proven Results</p>
      <blockquote class="sp-quote">
        <p class="sp-quote-metric">+125% organic traffic · +552% organic revenue</p>
        <p class="sp-quote-context">
          A full technical audit of Illuminated Mirrors' site uncovered crawlability
          issues and over-optimised content suppressing their rankings. After technical
          fixes, content rewrites, and an outreach campaign, organic revenue grew
          by 552% in six months.
        </p>
        <footer class="sp-quote-credit">— Illuminated Mirrors (eCommerce · UK)</footer>
      </blockquote>
    </div>
  </section>

  <!-- ── 5. Technical SEO in Manchester and Stockport (light) ──── -->
  <section class="sp-content section-light">
    <div class="container sp-content-inner reveal">
      <h2 class="sp-h2">Technical SEO Services in Manchester and Stockport</h2>
      <p>
        Whether you're based in Manchester city centre, Stockport, Cheshire, or anywhere
        across Greater Manchester, technical SEO issues affect every site regardless of size
        or sector. As a <strong>technical SEO consultant in Manchester</strong>, I work with
        local businesses, eCommerce stores, and professional services firms across the region
        to diagnose and fix the technical problems holding their sites back.
      </p>
      <p>
        Common issues I find and fix for Manchester and Stockport businesses:
      </p>
      <ul class="sp-list">
        <li>Slow page load times failing Core Web Vitals thresholds</li>
        <li>Crawl budget waste on large eCommerce sites</li>
        <li>Indexation problems where valuable pages aren't appearing in Google</li>
        <li>Broken internal link structures diluting page authority</li>
        <li>Missing or incorrect structured data (schema markup)</li>
        <li>Mobile usability issues causing ranking suppression</li>
        <li>Duplicate content created by CMS URL parameters</li>
      </ul>
      <p>
        Technical SEO works best alongside a broader strategy. Once the foundations are solid,
        <a href="/local-seo/" class="sp-inline-link">local SEO</a> and
        <a href="/on-page-seo/" class="sp-inline-link">on-page SEO</a>
        build on those foundations to drive consistent, measurable ranking improvements.
        As a <strong>technical SEO expert in Stockport</strong>, I provide
        <strong>technical SEO services</strong> that give every other aspect of your campaign
        the best possible platform to perform.
      </p>
    </div>
  </section>

  <!-- ── 6. FAQ (light) ──────────────────────────────────────── -->
  <section class="sp-content section-light">
    <div class="container sp-content-inner reveal">
      <h2 class="sp-h2">Frequently Asked Questions</h2>

      <dl class="page-faq-list">

        <div class="page-faq-item">
          <dt>
            <button class="page-faq-trigger" aria-expanded="false" aria-controls="pfaq-0" id="pfaq-btn-0">
              <span class="page-faq-question">What is included in a technical SEO audit?</span>
              <span class="page-faq-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <line x1="12" y1="5" x2="12" y2="19" class="pfaq-icon-v"/>
                  <line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
              </span>
            </button>
          </dt>
          <dd id="pfaq-0" class="page-faq-answer" role="region" aria-labelledby="pfaq-btn-0" hidden>
            <div class="page-faq-answer-inner">
              <p>A technical SEO audit covers crawlability and indexation, Core Web Vitals (LCP, CLS, INP), site architecture, structured data, site speed, mobile usability, HTTPS setup, duplicate content, and internal linking. You receive a prioritised action plan explaining each issue in plain language and how to fix it.</p>
            </div>
          </dd>
        </div>

        <div class="page-faq-item">
          <dt>
            <button class="page-faq-trigger" aria-expanded="false" aria-controls="pfaq-1" id="pfaq-btn-1">
              <span class="page-faq-question">How long does a technical SEO audit take?</span>
              <span class="page-faq-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <line x1="12" y1="5" x2="12" y2="19" class="pfaq-icon-v"/>
                  <line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
              </span>
            </button>
          </dt>
          <dd id="pfaq-1" class="page-faq-answer" role="region" aria-labelledby="pfaq-btn-1" hidden>
            <div class="page-faq-answer-inner">
              <p>For most small to medium business websites, a comprehensive technical SEO audit takes 3–5 days to complete. Larger eCommerce sites or those with complex architectures may take 7–10 days. You'll receive a full report with prioritised recommendations at the end.</p>
            </div>
          </dd>
        </div>

        <div class="page-faq-item">
          <dt>
            <button class="page-faq-trigger" aria-expanded="false" aria-controls="pfaq-2" id="pfaq-btn-2">
              <span class="page-faq-question">Can technical SEO issues cause ranking drops?</span>
              <span class="page-faq-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <line x1="12" y1="5" x2="12" y2="19" class="pfaq-icon-v"/>
                  <line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
              </span>
            </button>
          </dt>
          <dd id="pfaq-2" class="page-faq-answer" role="region" aria-labelledby="pfaq-btn-2" hidden>
            <div class="page-faq-answer-inner">
              <p>Yes — many ranking drops are caused by technical issues rather than content or link-related factors. Common culprits include accidental noindex tags, redirect chains diluting link equity, canonicalisation errors, and Core Web Vitals failures. Technical SEO should be the first thing investigated when rankings unexpectedly fall.</p>
            </div>
          </dd>
        </div>

        <div class="page-faq-item">
          <dt>
            <button class="page-faq-trigger" aria-expanded="false" aria-controls="pfaq-3" id="pfaq-btn-3">
              <span class="page-faq-question">Do I need ongoing technical SEO or is a one-off audit enough?</span>
              <span class="page-faq-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <line x1="12" y1="5" x2="12" y2="19" class="pfaq-icon-v"/>
                  <line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
              </span>
            </button>
          </dt>
          <dd id="pfaq-3" class="page-faq-answer" role="region" aria-labelledby="pfaq-btn-3" hidden>
            <div class="page-faq-answer-inner">
              <p>A one-off audit is a great starting point that surfaces the issues currently holding your site back. Ongoing technical SEO makes sense for sites that publish frequently, run major development projects, or need continuous monitoring for crawl errors, indexation problems, and Core Web Vitals regressions. I offer both.</p>
            </div>
          </dd>
        </div>

      </dl>
    </div>
  </section>

  <!-- ── 7. Contact CTA ───────────────────────────────────────── -->
  <ContactForm />

</ServicePage>

<style>
  /* ── Shared sub-page styles ──────────────────────────────────── */
  .section-dark  { background-color: var(--ink);   color: var(--chalk); }
  .section-light { background-color: var(--chalk);  color: var(--ink); }

  .container {
    max-width: 860px;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 5vw, 2rem);
  }

  .sp-hero { padding: 5rem 0 4rem; }
  .sp-hero-inner { display: flex; flex-direction: column; gap: 1.5rem; }

  .eyebrow {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0;
  }
  .dark-eyebrow { color: var(--accent); }

  .sp-h1 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--chalk);
    margin: 0;
  }

  .sp-intro {
    font-size: 1.125rem;
    line-height: 1.7;
    color: rgba(248, 247, 242, 0.75);
    max-width: 640px;
  }

  .sp-intro-sub {
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(248, 247, 242, 0.6);
    max-width: 640px;
  }

  .btn-primary {
    display: inline-block;
    background-color: var(--accent);
    color: #fff;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    font-weight: 500;
    padding: 0.8rem 1.75rem;
    border-radius: 4px;
    transition: background-color 0.2s ease;
    align-self: flex-start;
  }
  .btn-primary:hover { background-color: var(--accent-dk); }

  .sp-content { padding: 4rem 0; }
  .sp-content-inner { display: flex; flex-direction: column; gap: 1.5rem; }

  .sp-h2 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin: 0;
  }
  .sp-h2.chalk { color: var(--chalk); }

  .sp-h3 {
    font-family: 'Syne', sans-serif;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--ink);
    margin: 0.5rem 0 0;
  }

  .sp-content p, .sp-content-inner p {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: rgba(10, 10, 15, 0.8);
  }

  .sp-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .sp-list li {
    font-size: 1rem;
    line-height: 1.65;
    padding-left: 1.25rem;
    position: relative;
    color: rgba(10, 10, 15, 0.8);
  }
  .sp-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-size: 0.875rem;
  }

  .sp-why { padding: 4rem 0; }
  .sp-why-inner { display: flex; flex-direction: column; gap: 1.5rem; }
  .chalk { color: var(--chalk); }
  .chalk-muted {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: rgba(248, 247, 242, 0.75);
  }

  .sp-result { padding: 4rem 0; }
  .sp-result-inner { display: flex; flex-direction: column; gap: 1.5rem; }

  .sp-quote {
    margin: 0;
    padding: 2rem;
    border-left: 3px solid var(--accent);
    background-color: rgba(10, 10, 15, 0.04);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .sp-quote-metric {
    font-family: 'DM Mono', monospace;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--ink);
    margin: 0;
  }
  .sp-quote-context {
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(10, 10, 15, 0.75);
    margin: 0;
  }
  .sp-quote-credit {
    font-size: 0.875rem;
    color: var(--muted);
    font-style: normal;
  }

  .sp-inline-link {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: rgba(255, 104, 38, 0.45);
    text-underline-offset: 2px;
    transition: color 0.2s ease;
  }
  .sp-inline-link:hover { color: var(--accent-dk); }

  /* ── Page FAQ ────────────────────────────────────────────────── */
  .page-faq-list {
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .page-faq-item { border-bottom: 1px solid var(--border-light); }
  .page-faq-item:first-child { border-top: 1px solid var(--border-light); }
  .page-faq-trigger {
    width: 100%;
    background: none;
    border: none;
    padding: 1.375rem 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    cursor: pointer;
    text-align: left;
  }
  .page-faq-question {
    font-family: 'Syne', sans-serif;
    font-weight: 600;
    font-size: clamp(0.9375rem, 1.2vw, 1.0625rem);
    color: var(--ink);
    line-height: 1.4;
    letter-spacing: -0.01em;
  }
  .page-faq-icon {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid var(--border-light);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent-dk);
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }
  .page-faq-trigger:hover .page-faq-icon {
    background-color: rgba(10, 10, 15, 0.04);
    border-color: rgba(10, 10, 15, 0.2);
  }
  .pfaq-icon-v {
    transition: transform 0.25s ease, opacity 0.25s ease;
    transform-origin: center;
  }
  .page-faq-trigger[aria-expanded="true"] .pfaq-icon-v {
    transform: rotate(90deg);
    opacity: 0;
  }
  .page-faq-answer-inner { padding-bottom: 1.375rem; }
  .page-faq-answer-inner p {
    font-size: clamp(0.9375rem, 1.2vw, 1.0625rem);
    color: rgba(10, 10, 15, 0.7);
    line-height: 1.75;
    max-width: 65ch;
  }

  /* ── Scroll reveal ───────────────────────────────────────────── */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: none;
  }
</style>

<script>
  const revealEls = document.querySelectorAll('.reveal');
  const io = new IntersectionObserver(
    (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); } }),
    { threshold: 0.12 }
  );
  revealEls.forEach(el => io.observe(el));

  const pageFaqTriggers = document.querySelectorAll<HTMLButtonElement>('.page-faq-trigger');
  pageFaqTriggers.forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const expanded = trigger.getAttribute('aria-expanded') === 'true';
      const answerId = trigger.getAttribute('aria-controls')!;
      const answer = document.getElementById(answerId)!;
      pageFaqTriggers.forEach((t) => {
        if (t !== trigger) {
          t.setAttribute('aria-expanded', 'false');
          document.getElementById(t.getAttribute('aria-controls')!)!.hidden = true;
        }
      });
      trigger.setAttribute('aria-expanded', expanded ? 'false' : 'true');
      answer.hidden = expanded;
    });
  });
</script>
